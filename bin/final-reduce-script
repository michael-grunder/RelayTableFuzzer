#!/usr/bin/env php
<?php

declare(strict_types=1);

use Symfony\Component\Console\Application;
use Symfony\Component\Console\Command\Command;
use Symfony\Component\Console\Exception\ExceptionInterface;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Console\Input\InputArgument;
use Symfony\Component\Console\Input\InputInterface;
use Symfony\Component\Console\Input\InputOption;
use Symfony\Component\Console\Output\ConsoleOutput;
use Symfony\Component\Console\Output\ConsoleOutputInterface;
use Symfony\Component\Console\Output\ConsoleSectionOutput;
use Symfony\Component\Console\Output\OutputInterface;
use Symfony\Component\Console\Style\SymfonyStyle;

require_once __DIR__ . '/../vendor/autoload.php';

/**
 * @param list<string> $argv
 * @return list<string>
 */
function normalize_argv_for_symfony(array $argv): array
{
    if ($argv === []) {
        return $argv;
    }

    $normalized = [$argv[0]];
    $forwardedPhpArgs = [];
    $scriptPathSeen = false;

    $optionsWithRequiredValues = [
        '--php-bin' => true,
        '--php-ini' => true,
        '--max-runs' => true,
        '--timeout' => true,
        '--progress-mode' => true,
        '--interval' => true,
    ];

    for ($i = 1, $count = count($argv); $i < $count; $i++) {
        $arg = $argv[$i];

        if ($arg === '--') {
            $remaining = array_slice($argv, $i + 1);
            if ($remaining !== []) {
                if (!$scriptPathSeen) {
                    $normalized[] = '--';
                    $normalized = [...$normalized, ...$remaining];
                } else {
                    $forwardedPhpArgs = [...$forwardedPhpArgs, ...$remaining];
                }
            }
            break;
        }

        if (str_starts_with($arg, '--')) {
            $name = $arg;
            $value = null;
            if (str_contains($arg, '=')) {
                [$name, $value] = explode('=', $arg, 2);
            }

            $normalized[] = $arg;

            if (isset($optionsWithRequiredValues[$name]) && $value === null) {
                if (!isset($argv[$i + 1])) {
                    break;
                }
                $i++;
                $normalized[] = $argv[$i];
            }

            continue;
        }

        if ($arg !== '' && $arg[0] === '-') {
            if (is_symfony_global_short_option($arg)) {
                $normalized[] = $arg;
                continue;
            }

            $forwardedPhpArgs[] = $arg;
            if ($arg === '-d') {
                if (!isset($argv[$i + 1])) {
                    throw new InvalidArgumentException('Missing value for -d');
                }
                $i++;
                $forwardedPhpArgs[] = $argv[$i];
            }
            continue;
        }

        if (!$scriptPathSeen) {
            $normalized[] = $arg;
            $scriptPathSeen = true;
            continue;
        }

        $forwardedPhpArgs[] = $arg;
    }

    if ($forwardedPhpArgs !== []) {
        $normalized[] = '--';
        $normalized = [...$normalized, ...$forwardedPhpArgs];
    }

    return $normalized;
}

function is_symfony_global_short_option(string $arg): bool
{
    if ($arg === '-h' || $arg === '-V' || $arg === '-n' || $arg === '-q') {
        return true;
    }

    return preg_match('/^-v{1,3}$/', $arg) === 1;
}

function parse_max_runs(string $raw): int
{
    if ($raw === '' || preg_match('/^\d+$/', $raw) !== 1) {
        throw new InvalidArgumentException("Invalid --max-runs value: {$raw}");
    }

    $maxRuns = (int) $raw;
    if ($maxRuns < 1) {
        throw new InvalidArgumentException('--max-runs must be >= 1');
    }

    return $maxRuns;
}

function parse_timeout_seconds(string $raw): int
{
    if ($raw === '' || preg_match('/^\d+$/', $raw) !== 1) {
        throw new InvalidArgumentException("Invalid --timeout value: {$raw}");
    }

    $timeout = (int) $raw;
    if ($timeout < 1) {
        throw new InvalidArgumentException('--timeout must be >= 1');
    }

    return $timeout;
}

/**
 * @return 'plain'|'screen'
 */
function parse_progress_mode(string $raw): string
{
    $mode = strtolower(trim($raw));
    if (!in_array($mode, ['plain', 'screen'], true)) {
        throw new InvalidArgumentException("--progress-mode must be 'plain' or 'screen'");
    }

    return $mode;
}

function parse_render_interval(string $raw): float
{
    if ($raw === '' || !is_numeric($raw)) {
        throw new InvalidArgumentException("Invalid --interval value: {$raw}");
    }

    $interval = (float) $raw;
    if ($interval <= 0) {
        throw new InvalidArgumentException('--interval must be > 0');
    }

    return $interval;
}

function resolve_executable_path(string $binary): string
{
    if ($binary === '') {
        return $binary;
    }
    if (str_contains($binary, '/')) {
        $real = realpath($binary);
        return $real !== false ? $real : $binary;
    }

    $path = getenv('PATH');
    if (!is_string($path) || $path === '') {
        return $binary;
    }

    foreach (explode(PATH_SEPARATOR, $path) as $dir) {
        if ($dir === '') {
            continue;
        }
        $candidate = rtrim($dir, DIRECTORY_SEPARATOR) . DIRECTORY_SEPARATOR . $binary;
        if (is_file($candidate) && is_executable($candidate)) {
            return $candidate;
        }
    }

    return $binary;
}

function create_temp_log(string $prefix): ?string
{
    $path = tempnam(sys_get_temp_dir(), $prefix);
    return $path !== false ? $path : null;
}

function parse_valgrind_error_count(?string $path): ?int
{
    if (!is_string($path) || $path === '' || !is_file($path)) {
        return null;
    }

    $lines = @file($path, FILE_IGNORE_NEW_LINES);
    if ($lines === false) {
        return null;
    }

    for ($i = count($lines) - 1; $i >= 0; $i--) {
        $line = trim($lines[$i]);
        if ($line === '') {
            continue;
        }
        if (preg_match('/ERROR\s+SUMMARY:\s*(\d+)\s+errors/i', $line, $matches) === 1) {
            return (int) $matches[1];
        }
    }

    return null;
}

function comment_out_line(string $line): string
{
    $lineBreak = '';
    $content = $line;
    if (str_ends_with($line, "\r\n")) {
        $lineBreak = "\r\n";
        $content = substr($line, 0, -2);
    } elseif (str_ends_with($line, "\n")) {
        $lineBreak = "\n";
        $content = substr($line, 0, -1);
    }

    $commented = preg_replace('/^(\s*)/', '$1// ', $content, 1);
    if ($commented === null) {
        $commented = '// ' . $content;
    }

    return $commented . $lineBreak;
}

function terminal_width(): int
{
    $columns = getenv('COLUMNS');
    if (is_string($columns) && ctype_digit($columns)) {
        $width = (int) $columns;
        if ($width >= 40 && $width <= 500) {
            return $width;
        }
    }

    return 120;
}

function format_duration(int $seconds): string
{
    $hours = intdiv($seconds, 3600);
    $minutes = intdiv($seconds % 3600, 60);
    $secs = $seconds % 60;

    if ($hours > 0) {
        return sprintf('%dh %02dm %02ds', $hours, $minutes, $secs);
    }

    return sprintf('%dm %02ds', $minutes, $secs);
}

function format_label_value(string $label, string $value): string
{
    return sprintf('%-24s %s', $label . ':', $value);
}

/**
 * @param array<string, mixed> $progress
 */
function render_progress_screen(array $progress, ConsoleSectionOutput $section): void
{
    $width = terminal_width();
    $now = microtime(true);
    $elapsed = format_duration((int) ($now - (float) $progress['start_time']));
    $sinceLastReduction = format_duration((int) ($now - (float) $progress['last_reduction_at']));
    $bestOps = (int) $progress['best_ops'];
    $originalOps = (int) $progress['original_ops'];
    $reduction = $originalOps - $bestOps;
    $iteration = (int) $progress['test_count'];
    $currentOps = $progress['current_candidate_ops'] !== null ? (int) $progress['current_candidate_ops'] : null;
    $currentOpsText = $currentOps !== null ? (string) $currentOps : 'n/a';
    $lastResult = (string) ($progress['last_result'] ?? 'n/a');
    $lastExit = $progress['last_exit'] !== null ? (string) $progress['last_exit'] : 'n/a';
    $lastSignal = $progress['last_signal'] !== null ? (string) $progress['last_signal'] : 'n/a';
    $lastAttempts = (int) ($progress['last_attempts'] ?? 0);
    $bestScriptPath = (string) $progress['best_script_path'];
    $bestCommand = (string) $progress['best_command'];

    $lines = [];
    $lines[] = str_repeat('=', $width);
    $lines[] = str_pad('relay-table-fuzzer final-reduce-script', $width, ' ', STR_PAD_BOTH);
    $lines[] = str_repeat('-', $width);
    $lines[] = format_label_value('Elapsed', $elapsed);
    $lines[] = format_label_value('Since last reduction', $sinceLastReduction);
    $lines[] = format_label_value('Iteration', "{$iteration}/?");
    $lines[] = format_label_value('Current candidate ops', $currentOpsText);
    $lines[] = format_label_value('Best ops', "{$bestOps}/{$originalOps} ({$reduction} fewer)");
    $lines[] = format_label_value('Last result', "{$lastResult}, exit={$lastExit}, signal={$lastSignal}, attempts={$lastAttempts}");
    $lines[] = str_repeat('-', $width);
    $lines[] = format_label_value('Best script', $bestScriptPath);
    $lines[] = format_label_value('Best command', $bestCommand);
    $lines[] = str_repeat('=', $width);

    $section->clear();
    $section->writeln($lines);
}

/**
 * @param array<string, mixed> $progress
 */
function maybe_render_progress_screen(
    array $progress,
    float $interval,
    float &$lastRenderAt,
    ConsoleSectionOutput $section,
    bool $force = false
): void {
    $now = microtime(true);
    if (!$force && ($now - $lastRenderAt) < $interval) {
        return;
    }

    $lastRenderAt = $now;
    render_progress_screen($progress, $section);
}

/**
 * @param list<string> $phpArgs
 */
function render_best_command(
    string $phpBin,
    ?string $phpIni,
    array $phpArgs,
    string $scriptPath,
    ?int $timeoutSeconds,
    ?string $timeoutBin,
    ?string $valgrindBin
): string {
    $command = [$phpBin, ...$phpArgs];
    if ($phpIni !== null && $phpIni !== '') {
        $command[] = '-c';
        $command[] = $phpIni;
    }
    $command[] = $scriptPath;

    if ($valgrindBin !== null) {
        $command = build_valgrind_command($valgrindBin, '/tmp/final-reduce-script-best.valgrind.log', $command);
    }
    if ($timeoutSeconds !== null && $timeoutBin !== null) {
        $command = [$timeoutBin, (string) $timeoutSeconds, ...$command];
    }

    return implode(' ', array_map('escapeshellarg', $command));
}

/**
 * @param list<string> $lines
 */
function find_statement_end(array $lines, int $start): int
{
    $inSingle = false;
    $inDouble = false;
    $escape = false;
    $parenDepth = 0;
    $bracketDepth = 0;
    $braceDepth = 0;

    for ($idx = $start, $count = count($lines); $idx < $count; $idx++) {
        $line = $lines[$idx];
        $lineLen = strlen($line);

        for ($pos = 0; $pos < $lineLen; $pos++) {
            $ch = $line[$pos];

            if ($inSingle || $inDouble) {
                if ($escape) {
                    $escape = false;
                    continue;
                }
                if ($ch === '\\') {
                    $escape = true;
                    continue;
                }
                if ($inSingle && $ch === "'") {
                    $inSingle = false;
                    continue;
                }
                if ($inDouble && $ch === '"') {
                    $inDouble = false;
                    continue;
                }

                continue;
            }

            if ($ch === "'") {
                $inSingle = true;
                continue;
            }
            if ($ch === '"') {
                $inDouble = true;
                continue;
            }

            if ($ch === '(') {
                $parenDepth++;
                continue;
            }
            if ($ch === ')') {
                $parenDepth = max(0, $parenDepth - 1);
                continue;
            }
            if ($ch === '[') {
                $bracketDepth++;
                continue;
            }
            if ($ch === ']') {
                $bracketDepth = max(0, $bracketDepth - 1);
                continue;
            }
            if ($ch === '{') {
                $braceDepth++;
                continue;
            }
            if ($ch === '}') {
                $braceDepth = max(0, $braceDepth - 1);
                continue;
            }

            if ($ch === ';' && $parenDepth === 0 && $bracketDepth === 0 && $braceDepth === 0) {
                return $idx;
            }
        }
    }

    return $start;
}

/**
 * @param list<string> $lines
 * @return list<array{worker: int, start: int, end: int}>
 */
function collect_operations(array $lines): array
{
    $operations = [];
    $currentWorker = null;

    for ($idx = 0, $count = count($lines); $idx < $count; $idx++) {
        $line = $lines[$idx];

        if (preg_match('/^\s*case\s+(\d+)\s*:\s*$/', $line, $matches) === 1) {
            $currentWorker = (int) $matches[1];
            continue;
        }
        if (preg_match('/^\s*default\s*:\s*$/', $line) === 1) {
            $currentWorker = null;
            continue;
        }

        if ($currentWorker === null) {
            continue;
        }

        if (preg_match('/^\s*Table::/', $line) !== 1) {
            continue;
        }

        $end = find_statement_end($lines, $idx);
        $operations[] = [
            'worker' => $currentWorker,
            'start' => $idx,
            'end' => $end,
        ];
        $idx = $end;
    }

    return $operations;
}

/**
 * @param list<string> $lines
 * @param list<array{worker: int, start: int, end: int}> $operations
 * @param array<int, true> $activeOperationSet
 */
function build_script(array $lines, array $operations, array $activeOperationSet): string
{
    $mutatedLines = $lines;

    foreach ($operations as $operationId => $operation) {
        if (isset($activeOperationSet[$operationId])) {
            continue;
        }

        for ($lineIdx = $operation['start']; $lineIdx <= $operation['end']; $lineIdx++) {
            $mutatedLines[$lineIdx] = comment_out_line($mutatedLines[$lineIdx]);
        }
    }

    return implode('', $mutatedLines);
}

function write_temp_script(string $dir, string $contents): string
{
    $tmp = tempnam($dir, 'final-reduce-script-');
    if ($tmp === false) {
        throw new RuntimeException('Failed to create temp file');
    }

    $tmpPhp = $tmp . '.php';
    if (!@rename($tmp, $tmpPhp)) {
        @unlink($tmp);
        throw new RuntimeException('Failed to create temp file');
    }

    if (file_put_contents($tmpPhp, $contents) === false) {
        @unlink($tmpPhp);
        throw new RuntimeException('Failed to write temp script');
    }

    return $tmpPhp;
}

/**
 * @param list<string> $command
 * @return list<string>
 */
function build_valgrind_command(string $valgrindBin, string $logPath, array $command): array
{
    return [
        'env',
        'USE_ZEND_ALLOC=0',
        $valgrindBin,
        '--tool=memcheck',
        '--leak-check=no',
        '--errors-for-leak-kinds=none',
        '--log-file=' . $logPath,
        ...$command,
    ];
}

/**
 * @param list<string> $phpArgs
 * @return array{
 *   command: string,
 *   cwd: string,
 *   exit_code: int,
 *   signal: ?int,
 *   timed_out: bool,
 *   valgrind_errors: ?int,
 *   stdout: string,
 *   stderr: string
 * }
 */
function run_php_once(
    string $phpBin,
    ?string $phpIni,
    array $phpArgs,
    string $scriptPath,
    string $cwd,
    ?int $timeoutSeconds,
    ?string $timeoutBin,
    ?string $valgrindBin,
    ?callable $onTick
): array {
    $args = [$phpBin, ...$phpArgs];
    if ($phpIni !== null && $phpIni !== '') {
        $args[] = '-c';
        $args[] = $phpIni;
    }
    $args[] = $scriptPath;

    $valgrindLogPath = null;
    $exec = $args;
    if ($valgrindBin !== null) {
        $valgrindLogPath = create_temp_log('final-reduce-script-vg-');
        if ($valgrindLogPath === null) {
            throw new RuntimeException('Failed to create valgrind log file');
        }
        $exec = build_valgrind_command($valgrindBin, $valgrindLogPath, $exec);
    }
    if ($timeoutSeconds !== null && $timeoutBin !== null) {
        $exec = [$timeoutBin, (string) $timeoutSeconds, ...$exec];
    }

    $command = implode(' ', array_map('escapeshellarg', $exec));

    $descriptors = [
        0 => ['pipe', 'r'],
        1 => ['pipe', 'w'],
        2 => ['pipe', 'w'],
    ];

    $pipes = [];
    $proc = proc_open($exec, $descriptors, $pipes, $cwd);
    if (!is_resource($proc)) {
        throw new RuntimeException('Failed to execute PHP binary');
    }

    fclose($pipes[0]);
    stream_set_blocking($pipes[1], false);
    stream_set_blocking($pipes[2], false);

    $stdout = '';
    $stderr = '';
    /** @var array{command: string, pid: int, running: bool, signaled: bool, stopped: bool, exitcode: int, termsig: int, stopsig: int} $status */
    $status = proc_get_status($proc);
    while ($status['running']) {
        $read = [$pipes[1], $pipes[2]];
        $write = null;
        $except = null;
        @stream_select($read, $write, $except, 0, 200000);

        $outChunk = stream_get_contents($pipes[1]);
        if (is_string($outChunk) && $outChunk !== '') {
            $stdout .= $outChunk;
        }
        $errChunk = stream_get_contents($pipes[2]);
        if (is_string($errChunk) && $errChunk !== '') {
            $stderr .= $errChunk;
        }

        if ($onTick !== null) {
            $onTick();
        }

        $status = proc_get_status($proc);
    }

    $outChunk = stream_get_contents($pipes[1]);
    if (is_string($outChunk) && $outChunk !== '') {
        $stdout .= $outChunk;
    }
    fclose($pipes[1]);
    $errChunk = stream_get_contents($pipes[2]);
    if (is_string($errChunk) && $errChunk !== '') {
        $stderr .= $errChunk;
    }
    fclose($pipes[2]);

    $exitCode = proc_close($proc);

    $finalExit = null;
    $signal = null;
    if ($status['signaled']) {
        $signal = $status['termsig'];
        $finalExit = 128 + $signal;
    } elseif ($status['exitcode'] !== -1) {
        $finalExit = $status['exitcode'];
    }

    if ($finalExit === null && $exitCode !== -1) {
        $finalExit = $exitCode;
    }
    if ($finalExit === null) {
        $finalExit = 1;
    }

    $timedOut = $timeoutSeconds !== null && $finalExit === 124;
    $valgrindErrors = parse_valgrind_error_count($valgrindLogPath);
    if ($valgrindLogPath !== null) {
        @unlink($valgrindLogPath);
    }

    return [
        'command' => $command,
        'cwd' => $cwd,
        'exit_code' => $finalExit,
        'signal' => $signal,
        'timed_out' => $timedOut,
        'valgrind_errors' => $valgrindErrors,
        'stdout' => $stdout,
        'stderr' => $stderr,
    ];
}

function is_crash(int $exitCode): bool
{
    return $exitCode >= 128;
}

/**
 * @param array{
 *   command: string,
 *   cwd: string,
 *   exit_code: int,
 *   signal: ?int,
 *   timed_out: bool,
 *   valgrind_errors: ?int,
 *   stdout: string,
 *   stderr: string
 * } $run
 */
function classify_crash(array $run, bool $usesValgrind): bool
{
    if ($usesValgrind) {
        $errors = $run['valgrind_errors'] ?? null;
        return is_int($errors) && $errors > 0;
    }

    return is_crash((int) $run['exit_code']) || !empty($run['timed_out']);
}

/**
 * @param list<string> $phpArgs
 * @return array{
 *   is_crash: bool,
 *   attempts: int,
 *   last_run: array{
 *     command: string,
 *     cwd: string,
 *     exit_code: int,
 *     signal: ?int,
 *     timed_out: bool,
 *     valgrind_errors: ?int,
 *     stdout: string,
 *     stderr: string
 *   }|null
 * }
 */
function run_php_with_retries(
    string $phpBin,
    ?string $phpIni,
    array $phpArgs,
    string $scriptPath,
    string $cwd,
    int $maxRuns,
    ?int $timeoutSeconds,
    ?string $timeoutBin,
    ?string $valgrindBin,
    OutputInterface $output,
    bool $allowVerboseOutput,
    ?callable $onTick
): array {
    $lastRun = null;
    $usesValgrind = $valgrindBin !== null;

    for ($attempt = 1; $attempt <= $maxRuns; $attempt++) {
        $run = run_php_once(
            $phpBin,
            $phpIni,
            $phpArgs,
            $scriptPath,
            $cwd,
            $timeoutSeconds,
            $timeoutBin,
            $valgrindBin,
            $onTick
        );

        if ($allowVerboseOutput && $output->isVeryVerbose()) {
            $details = [];
            if (!empty($run['timed_out'])) {
                $details[] = 'timeout';
            }
            $valgrindErrors = $run['valgrind_errors'] ?? null;
            if (is_int($valgrindErrors)) {
                $details[] = "valgrind_errors={$valgrindErrors}";
            }

            $output->writeln(sprintf(
                '  attempt %d/%d: exit %d%s%s',
                $attempt,
                $maxRuns,
                $run['exit_code'],
                $run['signal'] !== null ? sprintf(', signal %d', $run['signal']) : '',
                $details !== [] ? ' [' . implode(', ', $details) . ']' : ''
            ));
            $output->writeln(sprintf('    stdout bytes: %d, stderr bytes: %d', strlen($run['stdout']), strlen($run['stderr'])));
            $output->writeln("    command: {$run['command']}");
        }

        $lastRun = $run;
        if (classify_crash($run, $usesValgrind)) {
            return [
                'is_crash' => true,
                'attempts' => $attempt,
                'last_run' => $run,
            ];
        }
    }

    return [
        'is_crash' => false,
        'attempts' => $maxRuns,
        'last_run' => $lastRun,
    ];
}

/**
 * @param list<int> $ops
 * @param callable(list<int>): bool $test
 * @return list<int>
 */
function ddmin(array $ops, callable $test): array
{
    $n = 2;
    $count = count($ops);

    while ($count >= 2) {
        $subsetSize = (int) ceil($count / $n);
        $reduced = false;

        for ($i = 0; $i < $n; $i++) {
            $start = $i * $subsetSize;
            if ($start >= $count) {
                break;
            }

            $subset = array_slice($ops, $start, $subsetSize);
            if ($subset !== [] && $test($subset)) {
                $ops = $subset;
                $count = count($ops);
                $n = 2;
                $reduced = true;
                break;
            }

            $complement = array_values(array_diff($ops, $subset));
            if ($complement !== [] && $test($complement)) {
                $ops = $complement;
                $count = count($ops);
                $n = max($n - 1, 2);
                $reduced = true;
                break;
            }
        }

        if ($reduced) {
            continue;
        }

        if ($n >= $count) {
            break;
        }
        $n = min($n * 2, $count);
    }

    return $ops;
}

final class FinalReduceScriptCommand extends Command
{
    public function __construct()
    {
        parent::__construct('final-reduce-script');
    }

    protected function configure(): void
    {
        $this
            ->setDescription('Reduce script-mode reproducers by removing worker Table:: statements.')
            ->addOption('php-bin', null, InputOption::VALUE_REQUIRED, 'Path to PHP binary', PHP_BINARY)
            ->addOption('php-ini', null, InputOption::VALUE_REQUIRED, 'Path to php.ini')
            ->addOption('max-runs', null, InputOption::VALUE_REQUIRED, 'Number of attempts per candidate', '1')
            ->addOption('timeout', null, InputOption::VALUE_REQUIRED, 'Kill runs that exceed N seconds')
            ->addOption('valgrind', null, InputOption::VALUE_OPTIONAL, 'Run under valgrind (optional custom binary path)')
            ->addOption('progress-mode', null, InputOption::VALUE_REQUIRED, 'Progress output mode: plain|screen', 'plain')
            ->addOption('interval', null, InputOption::VALUE_REQUIRED, 'Screen refresh interval in seconds', '1.0')
            ->addArgument('script_path', InputArgument::REQUIRED, 'Path to reproducer PHP script')
            ->addArgument('php_args', InputArgument::IS_ARRAY, 'Additional forwarded PHP args')
            ->setHelp(<<<'HELP'
Usage:
  bin/final-reduce-script [options] reproducer.php [php-arg ...]

Notes:
  - Any single-dash arg (for example -drelay.maxmemory=12345) is forwarded to PHP.
  - You can also pass "-d value" and both parts will be forwarded.
HELP);
    }

    protected function execute(InputInterface $input, OutputInterface $output): int
    {
        $io = new SymfonyStyle($input, $output);

        $phpBinOption = $input->getOption('php-bin');
        if (!is_string($phpBinOption) || $phpBinOption === '') {
            throw new InvalidArgumentException('Missing value for --php-bin');
        }

        $phpIniOption = $input->getOption('php-ini');
        if ($phpIniOption !== null && !is_string($phpIniOption)) {
            throw new InvalidArgumentException('Invalid --php-ini value');
        }

        $maxRunsOption = $input->getOption('max-runs');
        if (!is_string($maxRunsOption)) {
            throw new InvalidArgumentException('Missing value for --max-runs');
        }

        $timeoutOption = $input->getOption('timeout');
        if ($timeoutOption !== null && !is_string($timeoutOption)) {
            throw new InvalidArgumentException('Invalid --timeout value');
        }

        $valgrindOption = $input->getOption('valgrind');
        $valgrindBin = null;
        if ($valgrindOption !== null && $valgrindOption !== false) {
            if (!is_string($valgrindOption)) {
                throw new InvalidArgumentException('Invalid --valgrind value');
            }
            $valgrindBin = $valgrindOption !== '' ? $valgrindOption : 'valgrind';
        }

        $progressModeOption = $input->getOption('progress-mode');
        if (!is_string($progressModeOption)) {
            throw new InvalidArgumentException('Missing value for --progress-mode');
        }

        $intervalOption = $input->getOption('interval');
        if (!is_string($intervalOption)) {
            throw new InvalidArgumentException('Missing value for --interval');
        }

        $scriptPathArg = $input->getArgument('script_path');
        if (!is_string($scriptPathArg) || $scriptPathArg === '') {
            throw new InvalidArgumentException('Missing script path argument.');
        }

        $phpArgsArg = $input->getArgument('php_args');
        if (!is_array($phpArgsArg)) {
            throw new InvalidArgumentException('Invalid php args.');
        }
        /** @var list<string> $phpArgs */
        $phpArgs = array_values(array_map(static fn (mixed $item): string => (string) $item, $phpArgsArg));

        $maxRuns = parse_max_runs($maxRunsOption);
        $timeoutSeconds = $timeoutOption !== null ? parse_timeout_seconds($timeoutOption) : null;
        $progressMode = parse_progress_mode($progressModeOption);
        $renderInterval = parse_render_interval($intervalOption);

        $scriptPath = realpath($scriptPathArg);
        if ($scriptPath === false || !is_file($scriptPath)) {
            throw new RuntimeException("Script not found: {$scriptPathArg}");
        }

        $phpBin = resolve_executable_path($phpBinOption);
        if (!is_file($phpBin) || !is_executable($phpBin)) {
            throw new RuntimeException("PHP binary not found: {$phpBin}");
        }

        $phpIni = $phpIniOption;
        if ($phpIni !== null && $phpIni !== '') {
            $resolvedIni = realpath($phpIni);
            if ($resolvedIni === false || !is_file($resolvedIni)) {
                throw new RuntimeException("PHP ini not found: {$phpIni}");
            }
            $phpIni = $resolvedIni;
        }

        $timeoutBin = null;
        if (is_int($timeoutSeconds)) {
            $timeoutBin = resolve_executable_path('timeout');
            if (!is_file($timeoutBin) || !is_executable($timeoutBin)) {
                throw new RuntimeException('timeout binary not found or not executable: timeout');
            }
        }

        if ($valgrindBin !== null) {
            $valgrindBin = resolve_executable_path($valgrindBin);
            if (!is_file($valgrindBin) || !is_executable($valgrindBin)) {
                throw new RuntimeException("valgrind binary not found or not executable: {$input->getOption('valgrind')}");
            }
        }

        $lines = file($scriptPath);
        if ($lines === false) {
            throw new RuntimeException("Failed to read script: {$scriptPath}");
        }

        $operations = collect_operations($lines);
        if ($operations === []) {
            throw new RuntimeException('No worker Table:: operations found in script.');
        }

        $workerCounts = [];
        foreach ($operations as $operation) {
            $worker = $operation['worker'];
            $workerCounts[$worker] = ($workerCounts[$worker] ?? 0) + 1;
        }
        ksort($workerCounts);

        $scriptDir = dirname($scriptPath);
        $activeOperations = array_keys($operations);
        $originalCount = count($activeOperations);
        $scriptPathWithoutExtension = preg_replace('/\.php$/', '', $scriptPath);
        $outputPath = ($scriptPathWithoutExtension ?? $scriptPath) . '.final-reduced-script.php';
        $bestScriptPath = ($scriptPathWithoutExtension ?? $scriptPath) . '.final-reduced-script.best.php';

        $screenMode = $progressMode === 'screen';
        if ($screenMode && function_exists('stream_isatty') && !stream_isatty(STDOUT)) {
            $io->getErrorStyle()->warning('stdout is not a terminal; falling back to --progress-mode=plain');
            $screenMode = false;
        }

        $lastRenderAt = 0.0;
        $consoleOutput = $output instanceof ConsoleOutputInterface ? $output : new ConsoleOutput();
        $screenSection = $screenMode ? $consoleOutput->section() : null;

        $progress = [
            'start_time' => microtime(true),
            'last_reduction_at' => microtime(true),
            'test_count' => 0,
            'original_ops' => $originalCount,
            'current_candidate_ops' => null,
            'best_ops' => $originalCount,
            'best_script_path' => $bestScriptPath,
            'best_command' => render_best_command(
                $phpBin,
                $phpIni,
                $phpArgs,
                $bestScriptPath,
                $timeoutSeconds,
                $timeoutBin,
                $valgrindBin
            ),
            'last_result' => 'n/a',
            'last_exit' => null,
            'last_signal' => null,
            'last_attempts' => 0,
        ];

        if (!$screenMode) {
            $io->writeln('Final reduce (script mode) starting');
            $io->writeln("Script: {$scriptPath}");
            $io->writeln("PHP bin: {$phpBin}");
            if ($phpIni !== null && $phpIni !== '') {
                $io->writeln("PHP ini: {$phpIni}");
            }
            if (is_int($timeoutSeconds)) {
                $io->writeln("Timeout: {$timeoutSeconds}s ({$timeoutBin})");
            }
            if ($valgrindBin !== null) {
                $io->writeln("Valgrind: {$valgrindBin} (USE_ZEND_ALLOC=0)");
            }
            if ($phpArgs !== []) {
                $io->writeln('Forwarded PHP args: ' . implode(' ', array_map('escapeshellarg', $phpArgs)));
            }
            $io->writeln("Max runs per test: {$maxRuns}");
            $io->writeln(sprintf('Verbosity: %d', $output->getVerbosity()));
            $io->writeln("Worker operations: {$originalCount}");
        }

        $workerSummaryParts = [];
        foreach ($workerCounts as $worker => $count) {
            $workerSummaryParts[] = sprintf('worker %d=%d', $worker, $count);
        }
        if (!$screenMode) {
            $io->writeln('Workers: ' . implode(', ', $workerSummaryParts));
        }

        $baselineContents = build_script($lines, $operations, array_fill_keys($activeOperations, true));
        if (file_put_contents($bestScriptPath, $baselineContents) === false) {
            throw new RuntimeException("Failed to write best script snapshot: {$bestScriptPath}");
        }

        if ($screenMode && $screenSection !== null) {
            maybe_render_progress_screen($progress, $renderInterval, $lastRenderAt, $screenSection, true);
        }

        $testCount = 0;
        $test = function (array $candidateOperationIds) use (
            &$testCount,
            &$progress,
            &$lastRenderAt,
            $lines,
            $operations,
            $phpBin,
            $phpIni,
            $phpArgs,
            $maxRuns,
            $scriptDir,
            $timeoutSeconds,
            $timeoutBin,
            $valgrindBin,
            $screenMode,
            $renderInterval,
            $bestScriptPath,
            $output,
            $screenSection,
            $io
        ): bool {
            $testCount++;
            $progress['test_count'] = $testCount;
            $progress['current_candidate_ops'] = count($candidateOperationIds);
            if ($screenMode && $screenSection !== null) {
                maybe_render_progress_screen($progress, $renderInterval, $lastRenderAt, $screenSection);
            }

            $activeOperationSet = array_fill_keys($candidateOperationIds, true);
            $contents = build_script($lines, $operations, $activeOperationSet);
            $tmpScript = write_temp_script($scriptDir, $contents);

            $runResult = run_php_with_retries(
                $phpBin,
                $phpIni,
                $phpArgs,
                $tmpScript,
                $scriptDir,
                $maxRuns,
                $timeoutSeconds,
                $timeoutBin,
                $valgrindBin,
                $output,
                !$screenMode,
                $screenMode
                    ? static function () use (&$progress, $renderInterval, &$lastRenderAt, $screenSection): void {
                        if ($screenSection !== null) {
                            maybe_render_progress_screen($progress, $renderInterval, $lastRenderAt, $screenSection);
                        }
                    }
                    : null
            );

            @unlink($tmpScript);

            $run = $runResult['last_run'];
            if (!is_array($run)) {
                throw new RuntimeException('Failed to execute reducer test run');
            }

            $crash = (bool) $runResult['is_crash'];
            $candidateOps = count($candidateOperationIds);
            $progress['last_result'] = $crash ? 'crash' : 'no crash';
            $progress['last_exit'] = $run['exit_code'];
            $progress['last_signal'] = $run['signal'];
            $progress['last_attempts'] = $runResult['attempts'];
            if ($crash && $candidateOps < (int) $progress['best_ops']) {
                if (file_put_contents($bestScriptPath, $contents) === false) {
                    throw new RuntimeException("Failed to write best script snapshot: {$bestScriptPath}");
                }
                $progress['best_ops'] = $candidateOps;
                $progress['last_reduction_at'] = microtime(true);
                $progress['best_command'] = render_best_command(
                    $phpBin,
                    $phpIni,
                    $phpArgs,
                    $bestScriptPath,
                    $timeoutSeconds,
                    $timeoutBin,
                    $valgrindBin
                );
            }
            if ($screenMode && $screenSection !== null) {
                maybe_render_progress_screen($progress, $renderInterval, $lastRenderAt, $screenSection, true);
            }

            $result = $crash ? 'crash' : 'no crash';
            $details = [];
            if (!empty($run['timed_out'])) {
                $details[] = 'timeout';
            }
            $valgrindErrors = $run['valgrind_errors'] ?? null;
            if (is_int($valgrindErrors)) {
                $details[] = "valgrind_errors={$valgrindErrors}";
            }
            $detailSuffix = $details !== [] ? ' [' . implode(', ', $details) . ']' : '';

            if (!$screenMode) {
                $io->writeln(sprintf(
                    'test #%d: ops=%d => %s after %d/%d runs (exit %d%s)%s',
                    $testCount,
                    $candidateOps,
                    $result,
                    $runResult['attempts'],
                    $maxRuns,
                    $run['exit_code'],
                    $run['signal'] !== null ? sprintf(', signal %d', $run['signal']) : '',
                    $detailSuffix
                ));
            }

            if (!$screenMode && $output->isVerbose()) {
                $workers = [];
                foreach ($candidateOperationIds as $operationId) {
                    $worker = $operations[$operationId]['worker'];
                    $workers[$worker] = ($workers[$worker] ?? 0) + 1;
                }
                ksort($workers);
                $workerParts = [];
                foreach ($workers as $worker => $count) {
                    $workerParts[] = sprintf('%d=%d', $worker, $count);
                }
                $io->writeln('  candidate workers: ' . implode(', ', $workerParts));
            }

            if (!$screenMode && ($testCount === 1 || $output->isVerbose())) {
                $io->writeln("Command: {$run['command']}");
                $io->writeln("Cwd: {$run['cwd']}");
            }

            return $crash;
        };

        if (!$test($activeOperations)) {
            if ($valgrindBin !== null) {
                throw new RuntimeException('Baseline did not report valgrind memory errors within max runs; cannot reduce.');
            }
            throw new RuntimeException('Baseline did not crash or time out within max runs; cannot reduce.');
        }

        $reducedOperations = ddmin($activeOperations, $test);
        $finalCount = count($reducedOperations);

        if ($finalCount >= $originalCount) {
            $io->writeln("No reduction possible (still {$originalCount} operations).");
            return Command::SUCCESS;
        }

        $finalSet = array_fill_keys($reducedOperations, true);
        $finalContents = build_script($lines, $operations, $finalSet);

        if (file_put_contents($outputPath, $finalContents) === false) {
            throw new RuntimeException("Failed to write reduced script: {$outputPath}");
        }

        if (file_put_contents($bestScriptPath, $finalContents) === false) {
            throw new RuntimeException("Failed to write best script snapshot: {$bestScriptPath}");
        }

        if ($screenMode && $screenSection !== null) {
            $progress['best_ops'] = $finalCount;
            $progress['best_command'] = render_best_command(
                $phpBin,
                $phpIni,
                $phpArgs,
                $bestScriptPath,
                $timeoutSeconds,
                $timeoutBin,
                $valgrindBin
            );
            $progress['last_reduction_at'] = microtime(true);
            maybe_render_progress_screen($progress, $renderInterval, $lastRenderAt, $screenSection, true);
            $output->writeln('');
        }

        $io->writeln(sprintf('Reduced %d operations to %d operations.', $originalCount, $finalCount));
        $io->writeln("Reduced script: {$outputPath}");
        $io->writeln("Best-progress script: {$bestScriptPath}");

        return Command::SUCCESS;
    }
}

$application = new Application('relay-table-fuzzer final-reduce-script');
$application->addCommand(new FinalReduceScriptCommand());
$application->setDefaultCommand('final-reduce-script', true);

$rawArgv = $_SERVER['argv'] ?? [];
if (!is_array($rawArgv)) {
    $rawArgv = [];
}
/** @var list<string> $rawArgv */

try {
    $input = new ArgvInput(normalize_argv_for_symfony($rawArgv));
    $application->run($input);
} catch (InvalidArgumentException $e) {
    fwrite(STDERR, $e->getMessage() . "\n");
    exit(1);
} catch (ExceptionInterface $e) {
    fwrite(STDERR, $e->getMessage() . "\n");
    exit(1);
}
