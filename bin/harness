#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

use PhpTui\Tui\Color\AnsiColor;
use PhpTui\Tui\Display\Display;
use PhpTui\Tui\DisplayBuilder;
use PhpTui\Tui\Extension\Core\Widget\BlockWidget;
use PhpTui\Tui\Extension\Core\Widget\GridWidget;
use PhpTui\Tui\Extension\Core\Widget\ParagraphWidget;
use PhpTui\Tui\Extension\Core\Widget\Table\TableRow;
use PhpTui\Tui\Extension\Core\Widget\TableWidget;
use PhpTui\Tui\Layout\Constraint;
use PhpTui\Tui\Style\Modifier;
use PhpTui\Tui\Style\Style;
use PhpTui\Tui\Text\Title;
use PhpTui\Tui\Widget\Borders;
use PhpTui\Tui\Widget\Direction;

const CRASH_SIGNALS = [
    SIGSEGV,
    SIGBUS,
    SIGILL,
    SIGABRT,
    SIGFPE,
    SIGTRAP,
];

const SIGNAL_LABELS = [
    SIGSEGV => 'SIGSEGV',
    SIGBUS => 'SIGBUS',
    SIGILL => 'SIGILL',
    SIGABRT => 'SIGABRT',
    SIGFPE => 'SIGFPE',
    SIGTRAP => 'SIGTRAP',
];

const VALGRIND_ERROR_EXIT_CODE = 99;
const RECENT_REPRODUCER_LIMIT = 8;
const REPRODUCER_BUCKET_REPRODUCING = 'reproducing';
const REPRODUCER_BUCKET_NON_REPRODUCING = 'non-reproducing';
const REPRODUCER_BUCKET_REPRODUCABLE = 'reproducable';
const REPRODUCER_BUCKETS = [
    REPRODUCER_BUCKET_REPRODUCABLE,
    REPRODUCER_BUCKET_REPRODUCING,
    REPRODUCER_BUCKET_NON_REPRODUCING,
];

function usage(string $script): string
{
    return <<<USAGE
Usage:
  {$script} --php-bin /path/to/php [--php-ini /path/to/php.ini] [-d ini=val] [--mode fuzz|script] [--valgrind[=PATH]] [--rr] [--rr-chaos-mode] [--ops N] [--reduce] [--timeout N] [--timeout-signal SIG] [--only-crashes] [--capture-php-leaks] [--jobs N] [--interval SECONDS] [--repro-tries N] -- <command...>

Dynamic replacements in command arguments and -d values:
  {range}            -> random integer
  {range(lo,hi)}     -> random integer between lo and hi (inclusive)
  {hrtime}           -> hrtime(true)
  {ops}              -> value provided via --ops

Notes:
  --valgrind is only supported with --mode=script.
  --rr records each run with rr record; --rr-chaos-mode also passes -h to rr.
  --rr and --valgrind are mutually exclusive.
USAGE;
}

function render_command(array $command): string
{
    return implode(' ', array_map('escapeshellarg', $command));
}

function render_exec_command(array $command, ?string $rrTraceDir): string
{
    $rendered = render_command($command);
    if ($rrTraceDir === null || $rrTraceDir === '') {
        return $rendered;
    }

    return '_RR_TRACE_DIR=' . escapeshellarg($rrTraceDir) . ' ' . $rendered;
}

function signal_label(int $signal): string
{
    return SIGNAL_LABELS[$signal] ?? "SIG{$signal}";
}

function signal_description(int $signal): string
{
    if (function_exists('pcntl_strsignal')) {
        $desc = pcntl_strsignal($signal);
        if (is_string($desc) && $desc !== '') {
            return $desc;
        }
    }

    return '';
}

function elapsed_ms(float $start): int
{
    return max(0, (int)round((microtime(true) - $start) * 1000));
}

/**
 * @param array<string, bool|int|string|array<int, string>> $reportData
 */
function write_report_files(string $jobDir, array $reportData): void
{
    $report = [];
    foreach ($reportData as $key => $value) {
        if (is_array($value)) {
            $value = implode(', ', $value);
        } elseif (is_bool($value)) {
            $value = $value ? 'yes' : 'no';
        }
        $report[] = "{$key}: {$value}";
    }

    file_put_contents($jobDir . '/report.txt', implode("\n", $report) . "\n");
    file_put_contents(
        $jobDir . '/report.json',
        json_encode($reportData, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n"
    );
}

function replace_dynamic(string $arg): string
{
    $arg = preg_replace_callback('/\{range\((\-?\d+)\s*,\s*(\-?\d+)\)\}/', static function (array $matches): string {
        $lo = (int)$matches[1];
        $hi = (int)$matches[2];
        if ($lo > $hi) {
            [$lo, $hi] = [$hi, $lo];
        }

        return (string)random_int($lo, $hi);
    }, $arg);

    $arg = preg_replace_callback('/\{range\}/', static function (): string {
        return (string)random_int(0, PHP_INT_MAX);
    }, $arg);

    $arg = preg_replace_callback('/\{hrtime\}/', static function (): string {
        return (string)hrtime(true);
    }, $arg);

    return $arg;
}

function apply_ops(string $arg, ?int $ops): string
{
    if ($ops === null) {
        return $arg;
    }

    return str_replace('{ops}', (string)$ops, $arg);
}

function extract_ops_from_args(array $args): ?int
{
    $count = count($args);
    for ($i = 0; $i < $count; $i++) {
        $arg = $args[$i];
        if (!is_string($arg)) {
            continue;
        }

        if ($arg === '--ops') {
            $value = $args[$i + 1] ?? null;
            return is_numeric($value) ? (int) $value : null;
        }

        if (str_starts_with($arg, '--ops=')) {
            $value = substr($arg, strlen('--ops='));
            return is_numeric($value) ? (int) $value : null;
        }
    }

    return null;
}

/**
 * @param array<string, bool|int|string|array<int, string>> $reportData
 * @return array<string, bool|int|string|array<int, string>>
 */
function with_report_ops(array $reportData, ?int $ops): array
{
    if (isset($reportData['ops']) || $ops === null) {
        return $reportData;
    }

    $reportData['ops'] = $ops;
    return $reportData;
}

function build_php_command(string $phpBin, ?string $phpIni, array $phpArgs, array $runArgs): array
{
    $iniArgs = ($phpIni !== null && $phpIni !== '') ? ['-c', $phpIni] : [];
    return array_merge([$phpBin], $iniArgs, $phpArgs, $runArgs);
}

function build_valgrind_command(string $valgrindBin, string $logPath, array $command): array
{
    return array_merge(
        [
            $valgrindBin,
            '--error-exitcode=' . VALGRIND_ERROR_EXIT_CODE,
            '--track-origins=yes',
            '--log-file=' . $logPath,
            '--',
        ],
        $command
    );
}

function build_rr_command(string $rrBin, bool $rrChaosMode, array $command): array
{
    $rrCommand = [$rrBin, 'record'];
    if ($rrChaosMode) {
        $rrCommand[] = '-h';
    }

    return array_merge($rrCommand, $command);
}

function create_temp_log(string $prefix): ?string
{
    $path = tempnam(sys_get_temp_dir(), $prefix);
    return $path !== false ? $path : null;
}

function build_exec_command(
    array $command,
    ?string $valgrindBin,
    ?string $valgrindLogPath,
    ?string $rrBin = null,
    bool $rrChaosMode = false
): array {
    $exec = $command;
    if ($valgrindBin !== null && $valgrindLogPath !== null) {
        $exec = build_valgrind_command($valgrindBin, $valgrindLogPath, $exec);
    }
    if ($rrBin !== null) {
        $exec = build_rr_command($rrBin, $rrChaosMode, $exec);
    }

    return $exec;
}

function build_process_env(?string $rrTraceDir): ?array
{
    if ($rrTraceDir === null || $rrTraceDir === '') {
        return null;
    }

    $env = getenv();
    if (!is_array($env)) {
        $env = [];
    }
    $env['_RR_TRACE_DIR'] = $rrTraceDir;

    return $env;
}

function resolve_executable_path(string $binary): string
{
    if ($binary === '') {
        return $binary;
    }
    if (str_contains($binary, '/')) {
        $real = realpath($binary);
        return $real !== false ? $real : $binary;
    }

    $path = getenv('PATH');
    if (!is_string($path) || $path === '') {
        return $binary;
    }

    foreach (explode(PATH_SEPARATOR, $path) as $dir) {
        if ($dir === '') {
            continue;
        }
        $candidate = rtrim($dir, DIRECTORY_SEPARATOR) . DIRECTORY_SEPARATOR . $binary;
        if (is_file($candidate) && is_executable($candidate)) {
            return $candidate;
        }
    }

    return $binary;
}

function resolve_existing_file(string $path): ?string
{
    if ($path === '') {
        return null;
    }
    $real = realpath($path);
    if ($real === false || !is_file($real)) {
        return null;
    }

    return $real;
}

function display_path(string $path): string
{
    if ($path === '') {
        return $path;
    }

    $resolved = realpath($path);
    if ($resolved === false) {
        $resolved = $path;
    }

    $cwd = getcwd();
    if ($cwd === false) {
        return $resolved;
    }

    $base = realpath($cwd);
    if ($base === false) {
        return $resolved;
    }

    $base = rtrim($base, DIRECTORY_SEPARATOR);
    if ($resolved === $base) {
        return '.';
    }

    $prefix = $base . DIRECTORY_SEPARATOR;
    if (str_starts_with($resolved, $prefix)) {
        return './' . substr($resolved, strlen($prefix));
    }

    return $resolved;
}

function copy_php_ini(string $jobDir, ?string $phpIni): ?string
{
    if ($phpIni === null || $phpIni === '') {
        return null;
    }

    $source = resolve_existing_file($phpIni);
    if ($source === null) {
        return null;
    }

    $dest = $jobDir . '/' . basename($source);
    if (realpath($dest) === $source) {
        return $dest;
    }
    if (file_exists($dest)) {
        @unlink($dest);
    }
    if (!@copy($source, $dest)) {
        return null;
    }

    return $dest;
}

function write_run_reproducer(
    string $jobDir,
    string $phpBin,
    ?string $phpIni,
    array $phpArgs,
    ?string $valgrindBin,
    ?string $rrBin,
    bool $rrChaosMode
): void {
    $runnerPhpBin = resolve_executable_path($phpBin);
    $runnerPhpIni = copy_php_ini($jobDir, $phpIni);
    if ($runnerPhpIni === null && $phpIni !== null && $phpIni !== '') {
        $runnerPhpIni = resolve_existing_file($phpIni) ?? $phpIni;
    }

    $runnerPath = $jobDir . '/run-reproducer.sh';
    $jobRoot = realpath($jobDir) ?: $jobDir;
    $phpIniLine = null;
    $phpIniArg = null;
    if ($runnerPhpIni !== null && $runnerPhpIni !== '') {
        $iniRoot = realpath($runnerPhpIni);
        if ($iniRoot !== false && str_starts_with($iniRoot, $jobRoot . DIRECTORY_SEPARATOR)) {
            $phpIniLine = 'PHP_INI="$SCRIPT_DIR/' . basename($iniRoot) . '"';
        } else {
            $phpIniLine = 'PHP_INI=' . escapeshellarg($runnerPhpIni);
        }
        $phpIniArg = '"$PHP_INI"';
    }
    $phpArgsRendered = array_map('escapeshellarg', $phpArgs);
    $baseCommand = array_filter(array_merge(
        $valgrindBin !== null
            ? [
                '"$VALGRIND_BIN"',
                '"$VALGRIND_LOG_ARG"',
                '"$VALGRIND_ERROR_ARG"',
                '--',
            ]
            : [],
        ['"$PHP_BIN"'],
        $phpIniArg !== null ? ['-c', $phpIniArg] : [],
        $phpArgsRendered,
        ['"$SCRIPT_DIR/reproducer.php"']
    ), static fn (string $arg): bool => $arg !== '');
    $runnerCommand = $baseCommand;
    if ($rrBin !== null) {
        $runnerCommand = array_merge(
            ['"$RR_BIN"', 'record'],
            $rrChaosMode ? ['-h'] : [],
            $baseCommand
        );
    }
    $runnerLines = [
        '#!/usr/bin/env sh',
        '',
        '# Auto-generated by relay-table-fuzzer harness.',
        'SCRIPT_DIR=$(dirname "$(readlink -f "$0")")',
        'PHP_BIN=' . escapeshellarg($runnerPhpBin),
    ];
    if ($rrBin !== null) {
        $runnerLines[] = 'RR_BIN=' . escapeshellarg($rrBin);
        $runnerLines[] = 'RR_TRACE_DIR="$SCRIPT_DIR/rr-reproducer-trace"';
        $runnerLines[] = 'mkdir -p "$RR_TRACE_DIR"';
    }
    if ($valgrindBin !== null) {
        $runnerLines[] = 'VALGRIND_BIN=' . escapeshellarg($valgrindBin);
        $runnerLines[] = 'VALGRIND_LOG="$SCRIPT_DIR/valgrind.log"';
        $runnerLines[] = 'VALGRIND_LOG_ARG="--log-file=$VALGRIND_LOG"';
        $runnerLines[] = 'VALGRIND_ERROR_ARG="--error-exitcode=' . VALGRIND_ERROR_EXIT_CODE . '"';
    }
    if ($phpIniLine !== null) {
        $runnerLines[] = $phpIniLine;
    }
    $runnerLines[] = ($rrBin !== null ? '_RR_TRACE_DIR="$RR_TRACE_DIR" ' : '') . 'exec ' . implode(' ', $runnerCommand);
    file_put_contents($runnerPath, implode("\n", $runnerLines) . "\n");
    @chmod($runnerPath, 0755);

    write_php_shim($jobDir, $runnerPhpBin, $phpIniLine, $phpIniArg, $phpArgs);
}

function rewrite_saved_reproducer_command(
    string $jobDir,
    array &$reportData,
    string $phpBin,
    ?string $phpIni,
    array $phpArgs,
    ?string $valgrindBin,
    ?string $rrBin,
    bool $rrChaosMode
): void {
    $reproducerScript = $jobDir . '/reproducer.php';
    if (!is_file($reproducerScript)) {
        return;
    }

    $execCommand = build_exec_command(
        build_php_command($phpBin, $phpIni, $phpArgs, [$reproducerScript]),
        $valgrindBin,
        $valgrindBin !== null ? $jobDir . '/valgrind.log' : null,
        $rrBin,
        $rrChaosMode
    );
    $command = render_exec_command($execCommand, $rrBin !== null ? $jobDir . '/rr-reproducer-trace' : null);
    $reportData['command'] = $command;
    file_put_contents($jobDir . '/command.txt', $command . "\n");
    write_report_files($jobDir, $reportData);
}

function write_php_shim(
    string $jobDir,
    string $runnerPhpBin,
    ?string $phpIniLine,
    ?string $phpIniArg,
    array $phpArgs
): void {
    $shimPath = $jobDir . '/php';
    $phpArgsRendered = array_map('escapeshellarg', $phpArgs);
    $shimCommand = array_filter(array_merge(
        ['"$PHP_BIN"'],
        $phpIniArg !== null ? ['-c', $phpIniArg] : [],
        $phpArgsRendered,
        ['"$@"']
    ), static fn (string $arg): bool => $arg !== '');
    $shimLines = [
        '#!/usr/bin/env bash',
        '',
        '# Auto-generated by relay-table-fuzzer harness.',
        'SCRIPT_DIR=$(dirname "$(readlink -f "$0")")',
        'PHP_BIN=' . escapeshellarg($runnerPhpBin),
    ];
    if ($phpIniLine !== null) {
        $shimLines[] = $phpIniLine;
    }
    $shimLines[] = 'exec ' . implode(' ', $shimCommand);
    file_put_contents($shimPath, implode("\n", $shimLines) . "\n");
    @chmod($shimPath, 0755);
}

function create_temp_dir(string $prefix): string
{
    $tmp = tempnam(sys_get_temp_dir(), $prefix);
    if ($tmp === false) {
        fwrite(STDERR, "Failed to create temp path\n");
        exit(1);
    }
    @unlink($tmp);
    if (!mkdir($tmp, 0777, true) && !is_dir($tmp)) {
        fwrite(STDERR, "Failed to create temp dir: {$tmp}\n");
        exit(1);
    }
    return $tmp;
}

function create_reproducer_work_dir(string $storageDir): string
{
    $tmpRoot = $storageDir . '/.tmp';
    if (!is_dir($tmpRoot) && !mkdir($tmpRoot, 0777, true) && !is_dir($tmpRoot)) {
        fwrite(STDERR, "Failed to create temp dir root: {$tmpRoot}\n");
        exit(1);
    }

    for ($attempt = 0; $attempt < 100; $attempt++) {
        $jobDir = $tmpRoot . '/' . bin2hex(random_bytes(16));
        if (@mkdir($jobDir, 0777)) {
            return $jobDir;
        }
    }

    fwrite(STDERR, "Failed to allocate reproducer temp dir in {$tmpRoot}\n");
    exit(1);
}

function remove_dir_recursive(string $dir): void
{
    if (is_link($dir)) {
        @unlink($dir);
        return;
    }
    if (!is_dir($dir)) {
        return;
    }
    $entries = scandir($dir);
    if ($entries === false) {
        return;
    }
    foreach ($entries as $entry) {
        if ($entry === '.' || $entry === '..') {
            continue;
        }
        $path = $dir . '/' . $entry;
        if (is_dir($path) && !is_link($path)) {
            remove_dir_recursive($path);
            continue;
        }
        @unlink($path);
    }
    @rmdir($dir);
}

function copy_path_recursive(string $source, string $target): bool
{
    if (is_link($source)) {
        $linkTarget = readlink($source);
        return $linkTarget !== false && @symlink($linkTarget, $target);
    }

    if (!is_dir($source)) {
        return @copy($source, $target);
    }

    if (!is_dir($target) && !@mkdir($target, 0777, true) && !is_dir($target)) {
        return false;
    }

    $entries = scandir($source);
    if ($entries === false) {
        return false;
    }

    foreach ($entries as $entry) {
        if ($entry === '.' || $entry === '..') {
            continue;
        }
        if (!copy_path_recursive($source . '/' . $entry, $target . '/' . $entry)) {
            return false;
        }
    }

    return true;
}

function format_duration(int $seconds): string
{
    $days = intdiv($seconds, 86400);
    $seconds -= $days * 86400;
    $hours = intdiv($seconds, 3600);
    $seconds -= $hours * 3600;
    $minutes = intdiv($seconds, 60);
    $seconds -= $minutes * 60;

    if ($days > 0) {
        return sprintf('%dd %02d:%02d:%02d', $days, $hours, $minutes, $seconds);
    }

    return sprintf('%02d:%02d:%02d', $hours, $minutes, $seconds);
}

function format_age(int $timestamp, ?int $now = null): string
{
    $seconds = max(0, ($now ?? time()) - $timestamp);
    if ($seconds === 0) {
        return 'now';
    }

    $units = [
        'd' => 86400,
        'h' => 3600,
        'm' => 60,
        's' => 1,
    ];
    $parts = [];

    foreach ($units as $label => $unitSeconds) {
        $value = intdiv($seconds, $unitSeconds);
        if ($value === 0) {
            continue;
        }

        $parts[] = "{$value}{$label}";
        $seconds -= $value * $unitSeconds;

        if (count($parts) === 2) {
            break;
        }
    }

    return implode('', $parts);
}

function format_bytes(int $bytes): string
{
    $units = ['B', 'K', 'M', 'G', 'T'];
    $value = (float)$bytes;
    $unitIndex = 0;

    while ($value >= 1024 && $unitIndex < count($units) - 1) {
        $value /= 1024;
        $unitIndex++;
    }

    if ($unitIndex === 0) {
        return (string)$bytes;
    }

    $precision = $value >= 10 ? 0 : 1;
    $formatted = number_format($value, $precision, '.', '');
    $formatted = rtrim(rtrim($formatted, '0'), '.');

    return $formatted . $units[$unitIndex];
}

function terminal_width(): int
{
    $columns = getenv('COLUMNS');
    if (is_string($columns) && ctype_digit($columns)) {
        return max(60, (int)$columns);
    }

    return 80;
}

function truncate_text(string $text, int $width): string
{
    if ($width <= 0) {
        return '';
    }

    if (strlen($text) <= $width) {
        return $text;
    }

    if ($width <= 3) {
        return substr($text, 0, $width);
    }

    return substr($text, 0, $width - 3) . '...';
}

function pad_line(string $text, int $width): string
{
    $text = truncate_text($text, $width);
    return str_pad($text, $width);
}

function two_column(string $left, string $right, int $width, int $gap = 3, ?int $leftWidth = null): string
{
    $gap = max(1, $gap);
    if ($leftWidth === null) {
        $leftWidth = intdiv($width - $gap, 2);
    }

    $leftWidth = max(1, min($leftWidth, $width - $gap - 1));
    $rightWidth = max(1, $width - $gap - $leftWidth);

    $left = str_pad(truncate_text($left, $leftWidth), $leftWidth);
    $right = str_pad(truncate_text($right, $rightWidth), $rightWidth);

    return $left . str_repeat(' ', $gap) . $right;
}

function format_label_value(string $label, string $value, int $labelWidth = 12): string
{
    return str_pad($label, $labelWidth) . ': ' . $value;
}

function count_reproducer_dirs(string $reproducersDir): array
{
    if (!is_dir($reproducersDir)) {
        return ['total' => 0, 'reproducing' => 0];
    }

    $total = 0;
    $reproducing = 0;
    $entries = scandir($reproducersDir);
    if ($entries === false) {
        return ['total' => 0, 'reproducing' => 0];
    }

    foreach ($entries as $entry) {
        if ($entry === '.' || $entry === '..' || str_starts_with($entry, '.')) {
            continue;
        }
        $dir = $reproducersDir . '/' . $entry;
        if (!is_dir($dir)) {
            continue;
        }
        if (in_array($entry, REPRODUCER_BUCKETS, true)) {
            $subEntries = scandir($dir);
            if ($subEntries === false) {
                continue;
            }
            foreach ($subEntries as $subEntry) {
                if ($subEntry === '.' || $subEntry === '..') {
                    continue;
                }
                if (!is_dir($dir . '/' . $subEntry)) {
                    continue;
                }
                $total++;
                if ($entry === REPRODUCER_BUCKET_REPRODUCING || $entry === REPRODUCER_BUCKET_REPRODUCABLE) {
                    $reproducing++;
                }
            }
            continue;
        }
        $total++;
    }

    return ['total' => $total, 'reproducing' => $reproducing];
}

function create_tui_display(): ?Display
{
    static $display = null;
    static $initialized = false;

    if ($initialized) {
        return $display;
    }

    $initialized = true;
    try {
        $display = DisplayBuilder::default()->fullscreen()->build();
        $display->clear();
    } catch (Throwable) {
        $display = null;
    }

    return $display;
}

function harness_block(string $title, \PhpTui\Tui\Widget\Widget $widget): BlockWidget
{
    return BlockWidget::default()
        ->borders(Borders::ALL)
        ->titles(Title::fromString($title))
        ->borderStyle(Style::default()->fg(AnsiColor::DarkGray))
        ->titleStyle(Style::default()->fg(AnsiColor::LightCyan)->addModifier(Modifier::BOLD))
        ->widget($widget);
}

function read_reproducer_report(string $dir): array
{
    $path = $dir . '/report.json';
    if (!is_file($path)) {
        return [];
    }

    $json = file_get_contents($path);
    if (!is_string($json)) {
        return [];
    }

    $data = json_decode($json, true);
    return is_array($data) ? $data : [];
}

function reproducer_failure_type(array $report, string $bucket, string $dir): string
{
    if (isset($report['leak_count']) && is_numeric($report['leak_count'])) {
        return 'LEAKS:' . (string) $report['leak_count'];
    }

    if (isset($report['valgrind_errors']) && is_numeric($report['valgrind_errors']) && (int) $report['valgrind_errors'] > 0) {
        return 'VALGRIND:' . (string) $report['valgrind_errors'];
    }

    $gdbErrorType = extract_gdb_error_type($dir);
    if ($gdbErrorType !== null) {
        return $gdbErrorType;
    }

    if (isset($report['exit_type']) && is_string($report['exit_type']) && $report['exit_type'] !== '') {
        return $report['exit_type'];
    }

    if (isset($report['exit_name']) && is_string($report['exit_name']) && $report['exit_name'] !== '') {
        return normalize_failure_label($report['exit_name']);
    }

    if (isset($report['signal']) && is_string($report['signal']) && $report['signal'] !== '' && $report['signal'] !== 'none') {
        return signal_error_type($report['signal']);
    }

    return $bucket === 'leaks' ? 'LEAK' : 'UNKNOWN';
}

function normalize_failure_label(string $label): string
{
    if (preg_match('/^core(?:\s|$)/i', $label) === 1) {
        return 'core';
    }

    return $label;
}

function signal_error_type(string $signal): string
{
    return match (strtoupper($signal)) {
        'SIGSEGV' => 'SEGFAULT',
        'SIGBUS' => 'BUS_ERROR',
        'SIGILL' => 'ILLEGAL_INSTRUCTION',
        'SIGABRT' => 'ABORT',
        'SIGFPE' => 'FLOATING_POINT_EXCEPTION',
        'SIGTRAP' => 'TRAP',
        default => $signal,
    };
}

function extract_gdb_error_type(string $dir): ?string
{
    foreach (gdb_backtrace_paths($dir) as $path) {
        $lines = @file($path, FILE_IGNORE_NEW_LINES);
        if ($lines === false) {
            continue;
        }

        $signalType = null;
        $function = null;
        foreach ($lines as $line) {
            if (preg_match('/\b(?:Program terminated with|Program received|Thread \d+ .* received) signal (SIG[A-Z0-9]+)/', $line, $matches) === 1) {
                $signalType = signal_error_type($matches[1]);
                continue;
            }

            if ($function === null && preg_match('/^#0\s+.*?\bin\s+([^\s(]+)\s*(?:\(|$)/', $line, $matches) === 1) {
                $function = $matches[1];
            }

            if ($signalType !== null && $function !== null) {
                return "{$signalType}({$function})";
            }
        }

        if ($signalType !== null) {
            return $signalType;
        }
    }

    return null;
}

/** @return list<string> */
function gdb_backtrace_paths(string $dir): array
{
    $entries = scandir($dir);
    if ($entries === false) {
        return [];
    }

    $paths = [];
    foreach ($entries as $entry) {
        if (preg_match('/^gdb-(?:timeout-)?backtrace(?:-simple)?(?:-.+)?\.txt$/', $entry) !== 1) {
            continue;
        }
        $paths[] = $dir . '/' . $entry;
    }

    usort($paths, static function (string $a, string $b): int {
        $aSimple = str_contains(basename($a), 'simple') ? 0 : 1;
        $bSimple = str_contains(basename($b), 'simple') ? 0 : 1;

        return ($aSimple <=> $bSimple) ?: strcmp($a, $b);
    });

    return $paths;
}

function collect_recent_reproducers(array $roots, int $limit): array
{
    $entries = [];

    foreach ($roots as $root) {
        if (!is_string($root) || $root === '' || !is_dir($root)) {
            continue;
        }

        $rootType = basename($root) === 'leaks' ? 'leaks' : 'reproducers';
        foreach (REPRODUCER_BUCKETS as $bucket) {
            $bucketDir = $root . '/' . $bucket;
            if (!is_dir($bucketDir)) {
                continue;
            }

            $children = scandir($bucketDir);
            if ($children === false) {
                continue;
            }

            foreach ($children as $child) {
                if ($child === '.' || $child === '..') {
                    continue;
                }

                $dir = $bucketDir . '/' . $child;
                if (!is_dir($dir)) {
                    continue;
                }

                $report = read_reproducer_report($dir);
                $reportPath = $dir . '/report.json';
                $mtime = max(
                    filemtime($dir) ?: 0,
                    is_file($reportPath) ? (filemtime($reportPath) ?: 0) : 0
                );

                $entries[] = [
                    'time' => $mtime,
                    'failure_type' => reproducer_failure_type($report, $rootType, $dir),
                    'ops' => isset($report['ops']) && is_numeric($report['ops']) ? (int) $report['ops'] : null,
                    'path' => display_path($dir),
                ];
            }
        }
    }

    usort($entries, static fn (array $a, array $b): int => ($b['time'] <=> $a['time']) ?: strcmp((string) $b['path'], (string) $a['path']));

    return array_slice($entries, 0, $limit);
}

function render_recent_reproducers_table(array $entries): TableWidget
{
    $rows = [];
    $now = time();
    foreach ($entries as $entry) {
        $rows[] = TableRow::fromStrings(
            format_age((int) $entry['time'], $now),
            (string) $entry['failure_type'],
            $entry['ops'] !== null ? (string) $entry['ops'] : '-',
            (string) $entry['path'],
        );
    }

    if ($rows === []) {
        $rows[] = TableRow::fromStrings('-', 'none', '-', 'no reproducers saved yet');
    }

    return TableWidget::default()
        ->header(TableRow::fromStrings('Age', 'Failure', 'Ops', 'Path'))
        ->widths(
            Constraint::length(7),
            Constraint::length(32),
            Constraint::length(8),
            Constraint::min(20),
        )
        ->rows(...$rows);
}

function render_screen(array $stats, ?int $currentOps, string $mode): void
{
    $display = create_tui_display();
    $width = $display !== null ? max(60, $display->viewportArea()->width) : terminal_width();
    $height = $display !== null ? max(12, $display->viewportArea()->height) : 24;
    $now = microtime(true);
    $elapsed = format_duration((int)($now - $stats['start_time']));
    $sinceFailure = $stats['last_failure_time'] !== null
        ? format_duration((int)($now - $stats['last_failure_time']))
        : 'never';

    $statusWidth = max(1, $width - 2);
    $lines = [];
    $activeJobs = $stats['active_jobs'] ?? 1;
    $opsLabel = $currentOps !== null ? (string)$currentOps : 'n/a';
    $reproducersTotal = $stats['reproducers'] ?? 0;
    $reproducersReproducing = $stats['reproducers_reproducing'] ?? 0;
    $reproducersLabel = number_format($reproducersTotal) . ' (' . number_format($reproducersReproducing) . ' reproducing)';
    $labelWidth = strlen('Last reproducer');
    $pairs = [
        [
            format_label_value('Elapsed', $elapsed, $labelWidth),
            format_label_value('Runs', number_format($stats['runs']), $labelWidth),
        ],
        [
            format_label_value('Jobs', (string)$activeJobs, $labelWidth),
            format_label_value('Reproducers', $reproducersLabel, $labelWidth),
        ],
        [
            format_label_value('Last failure', $sinceFailure, $labelWidth),
            format_label_value('Reductions', number_format($stats['reductions']), $labelWidth),
        ],
        [
            format_label_value('Ops', $opsLabel, $labelWidth),
            format_label_value('Mode', $mode, $labelWidth),
        ],
    ];
    $maxLeft = 0;
    $maxRight = 0;
    foreach ($pairs as [$left, $right]) {
        $maxLeft = max($maxLeft, strlen($left));
        $maxRight = max($maxRight, strlen($right));
    }
    $gap = 3;
    $leftWidth = min($maxLeft, max(1, $statusWidth - $gap - 1));
    if ($maxRight > 0 && $leftWidth + $gap + $maxRight > $statusWidth) {
        $leftWidth = max(1, $statusWidth - $gap - $maxRight);
    }
    foreach ($pairs as [$left, $right]) {
        $lines[] = two_column($left, $right, $statusWidth, $gap, $leftWidth);
    }
    $memoryLabel = 'n/a';
    $relayMemory = $stats['relay_memory'] ?? null;
    if (is_array($relayMemory)) {
        $used = format_bytes((int)($relayMemory['used'] ?? 0));
        $total = format_bytes((int)($relayMemory['total'] ?? 0));
        $memoryLabel = "{$used}/{$total}";
    }
    $lines[] = format_label_value('Relay mem', $memoryLabel, $labelWidth);
    $lastFailure = $stats['last_failure_summary'] !== '' ? $stats['last_failure_summary'] : 'none';
    $event = $stats['last_event'] !== '' ? $stats['last_event'] : 'none';
    $lines[] = two_column(
        format_label_value('Last crash', $lastFailure, $labelWidth),
        format_label_value('Event', $event, $labelWidth),
        $statusWidth,
        $gap,
        $leftWidth
    );
    $lastRepro = $stats['last_reproducer'] !== '' ? display_path((string) $stats['last_reproducer']) : 'n/a';
    $lines[] = truncate_text(format_label_value('Last reproducer', $lastRepro, $labelWidth), $statusWidth);
    $command = $stats['last_command'] ?? '';
    $commandText = "Command: {$command}";

    if ($display === null) {
        $recent = collect_recent_reproducers($stats['recent_reproducer_roots'] ?? [], RECENT_REPRODUCER_LIMIT);
        $now = time();
        $lines[] = str_repeat('-', $width);
        $lines[] = pad_line($commandText, $width);
        $lines[] = str_repeat('-', $width);
        $lines[] = pad_line('Recent reproducers', $width);
        foreach ($recent as $entry) {
            $lines[] = pad_line(sprintf(
                '%-7s  %-16s  %-3s  %s',
                format_age((int) $entry['time'], $now),
                (string) $entry['failure_type'],
                (string) $entry['reproducing'],
                (string) $entry['path']
            ), $width);
        }
        $lines[] = str_repeat('=', $width);
        fwrite(STDOUT, "\033[2J\033[H" . implode("\n", $lines) . "\n");
        fflush(STDOUT);
        return;
    }

    $statusHeight = count($lines) + 2;
    $commandHeight = 3;
    $recentLimit = max(1, min(RECENT_REPRODUCER_LIMIT, $height - $statusHeight - $commandHeight - 2));
    $recent = collect_recent_reproducers($stats['recent_reproducer_roots'] ?? [], $recentLimit);
    $summary = harness_block(
        'Status',
        ParagraphWidget::fromString(implode("\n", $lines))
    );
    $commandBlock = harness_block(
        'Command',
        ParagraphWidget::fromString($commandText)
    );
    $recentBlock = harness_block(
        'Recent reproducers',
        render_recent_reproducers_table($recent)
    );

    $display->draw(
        GridWidget::default()
            ->direction(Direction::Vertical)
            ->constraints(
                Constraint::length($statusHeight),
                Constraint::length($commandHeight),
                Constraint::min(5),
            )
            ->widgets($summary, $commandBlock, $recentBlock)
    );
}

function maybe_render_screen(
    array $stats,
    ?int $currentOps,
    string $mode,
    float $interval,
    float &$lastRenderTime,
    bool $force = false
): void {
    $now = microtime(true);
    if (!$force && $interval > 0 && ($now - $lastRenderTime) < $interval) {
        return;
    }

    $lastRenderTime = $now;
    render_screen($stats, $currentOps, $mode);
}

function find_core_dumps(string $phpBin, ?int $pid, ?float $startTime = null): array
{
    $binary = basename($phpBin);
    if ($pid !== null) {
        $pattern = "/tmp/core.{$binary}.{$pid}.*";
        $cores = glob($pattern);
        return $cores !== false ? $cores : [];
    }

    if ($startTime === null) {
        return [];
    }

    $pattern = "/tmp/core.{$binary}.*";
    $cores = glob($pattern);
    if ($cores === false) {
        return [];
    }

    $cutoff = max(0, (int)$startTime - 1);
    return array_values(array_filter($cores, static function (string $path) use ($cutoff): bool {
        $mtime = @filemtime($path);
        return $mtime !== false && $mtime >= $cutoff;
    }));
}

/**
 * @param array<int, true> $seen
 * @return array<int, true>
 */
function collect_process_tree_pids(?int $pid, array &$seen = []): array
{
    if ($pid === null || $pid <= 0 || isset($seen[$pid])) {
        return $seen;
    }

    $seen[$pid] = true;
    $childrenPath = "/proc/{$pid}/task/{$pid}/children";
    $children = @file_get_contents($childrenPath);
    if (!is_string($children) || trim($children) === '') {
        return $seen;
    }

    foreach (preg_split('/\s+/', trim($children)) ?: [] as $childPid) {
        if (ctype_digit($childPid)) {
            collect_process_tree_pids((int)$childPid, $seen);
        }
    }

    return $seen;
}

/**
 * @param array<int, true> $pids
 * @return list<string>
 */
function find_core_dumps_for_pids(string $phpBin, array $pids): array
{
    $cores = [];
    foreach (array_keys($pids) as $pid) {
        foreach (find_core_dumps($phpBin, (int)$pid) as $coreFile) {
            $cores[$coreFile] = true;
        }
    }

    $paths = array_keys($cores);
    sort($paths);

    return $paths;
}

function parse_timeout_signal(?string $value): ?array
{
    if ($value === null || $value === '') {
        return null;
    }

    if (ctype_digit($value)) {
        return ['arg' => $value, 'num' => (int)$value];
    }

    $name = strtoupper($value);
    if (strpos($name, 'SIG') !== 0) {
        $name = 'SIG' . $name;
    }

    if (!defined($name)) {
        return null;
    }

    return ['arg' => $name, 'num' => (int)constant($name)];
}

function run_command(
    array $fullCommand,
    string $phpBin,
    ?int $maxSeconds,
    ?string $timeoutSignalArg,
    ?int $timeoutSignal,
    bool $onlyCrashes,
    ?string $valgrindBin,
    ?string $rrBin = null,
    bool $rrChaosMode = false
): array {
    $stdoutPath = tempnam(sys_get_temp_dir(), 'relay-harness-out-');
    $stderrPath = tempnam(sys_get_temp_dir(), 'relay-harness-err-');
    $valgrindLogPath = $valgrindBin !== null ? create_temp_log('relay-harness-vg-') : null;
    if ($valgrindBin !== null && $valgrindLogPath === null) {
        fwrite(STDERR, "Failed to create valgrind log file\n");
        exit(1);
    }
    $descriptorSpec = [
        0 => ['file', 'php://stdin', 'r'],
        1 => ['file', $stdoutPath !== false ? $stdoutPath : 'php://stdout', 'w'],
        2 => ['file', $stderrPath !== false ? $stderrPath : 'php://stderr', 'w'],
    ];

    $rrTraceDir = $rrBin !== null ? create_temp_dir('relay-harness-rr-') : null;
    $execCommand = build_exec_command($fullCommand, $valgrindBin, $valgrindLogPath, $rrBin, $rrChaosMode);
    $process = proc_open($execCommand, $descriptorSpec, $pipes, null, build_process_env($rrTraceDir));
    if (!is_resource($process)) {
        if ($rrTraceDir !== null) {
            remove_dir_recursive($rrTraceDir);
        }
        fwrite(STDERR, "Failed to start process\n");
        exit(1);
    }

    $start = microtime(true);
    $status = proc_get_status($process);
    $pid = $status['pid'] ?? null;
    $observedPids = collect_process_tree_pids(is_int($pid) ? $pid : null);
    $timeoutBacktracePath = null;
    $timeoutBacktraceSimplePath = null;
    $timedOut = false;
    $timeoutRequestedAt = null;

    while ($status['running']) {
        collect_process_tree_pids(is_int($pid) ? $pid : null, $observedPids);
        if (
            !$timedOut
            && $maxSeconds !== null
            && (microtime(true) - $start) >= $maxSeconds
        ) {
            $timedOut = true;
            [$timeoutBacktracePath, $timeoutBacktraceSimplePath] = capture_timeout_backtraces($pid);
            proc_terminate($process, $timeoutSignal ?? SIGTERM);
            $timeoutRequestedAt = microtime(true);
        } elseif ($timedOut && $timeoutRequestedAt !== null && (microtime(true) - $timeoutRequestedAt) >= 1.0) {
            proc_terminate($process, SIGKILL);
        }

        usleep(10000);
        $status = proc_get_status($process);
    }

    if ($status['running']) {
        for ($i = 0; $i < 50; $i++) {
            usleep(100000);
            $status = proc_get_status($process);
            if (!$status['running']) {
                break;
            }
        }
    }

    $exitCode = proc_close($process);

    $signal = null;
    if (($status['signaled'] ?? false) && isset($status['termsig'])) {
        $signal = (int)$status['termsig'];
    } elseif ($exitCode !== 0 && $exitCode > 128) {
        $signal = $exitCode - 128;
    }

    if ($timedOut) {
        $signal = null;
    }

    $usesTimeout = $maxSeconds !== null;
    $coreFiles = find_core_dumps_for_pids($phpBin, $observedPids);
    if ($coreFiles === [] && $timedOut && $usesTimeout) {
        $coreFiles = find_core_dumps($phpBin, null, $start);
    }
    $isCrash = ($signal !== null && in_array($signal, CRASH_SIGNALS, true)) || $coreFiles !== [];
    $valgrindErrors = parse_valgrind_error_count($valgrindLogPath);
    if (is_int($valgrindErrors) && $valgrindErrors > 0) {
        $isCrash = true;
    }
    if (!$onlyCrashes) {
        $isCrash = $timedOut || $isCrash;
    }

    return [
        'exit_code' => $exitCode,
        'execution_ms' => elapsed_ms($start),
        'signal' => $signal,
        'pid' => $pid,
        'timed_out' => $timedOut,
        'is_crash' => $isCrash,
        'core_files' => $coreFiles,
        'timeout_signal' => $timedOut ? $timeoutSignalArg : null,
        'stdout_path' => $stdoutPath !== false ? $stdoutPath : null,
        'stderr_path' => $stderrPath !== false ? $stderrPath : null,
        'valgrind_log_path' => $valgrindLogPath,
        'valgrind_errors' => $valgrindErrors,
        'rr_trace_dir' => $rrTraceDir,
        'rr_chaos_mode' => $rrBin !== null ? $rrChaosMode : null,
        'timeout_backtrace_path' => $timeoutBacktracePath,
        'timeout_backtrace_simple_path' => $timeoutBacktraceSimplePath,
    ];
}

function start_command(
    array $fullCommand,
    string $phpBin,
    ?int $maxSeconds,
    ?string $timeoutSignalArg,
    ?int $timeoutSignal,
    ?string $valgrindBin,
    ?string $rrBin = null,
    bool $rrChaosMode = false
): array {
    $stdoutPath = tempnam(sys_get_temp_dir(), 'relay-harness-out-');
    $stderrPath = tempnam(sys_get_temp_dir(), 'relay-harness-err-');
    $valgrindLogPath = $valgrindBin !== null ? create_temp_log('relay-harness-vg-') : null;
    if ($valgrindBin !== null && $valgrindLogPath === null) {
        fwrite(STDERR, "Failed to create valgrind log file\n");
        exit(1);
    }
    $descriptorSpec = [
        0 => ['file', 'php://stdin', 'r'],
        1 => ['file', $stdoutPath !== false ? $stdoutPath : 'php://stdout', 'w'],
        2 => ['file', $stderrPath !== false ? $stderrPath : 'php://stderr', 'w'],
    ];

    $rrTraceDir = $rrBin !== null ? create_temp_dir('relay-harness-rr-') : null;
    $execCommand = build_exec_command($fullCommand, $valgrindBin, $valgrindLogPath, $rrBin, $rrChaosMode);
    $process = proc_open($execCommand, $descriptorSpec, $pipes, null, build_process_env($rrTraceDir));
    if (!is_resource($process)) {
        if ($rrTraceDir !== null) {
            remove_dir_recursive($rrTraceDir);
        }
        fwrite(STDERR, "Failed to start process\n");
        exit(1);
    }

    $status = proc_get_status($process);

    return [
        'process' => $process,
        'pid' => $status['pid'] ?? null,
        'observed_pids' => collect_process_tree_pids(is_int($status['pid'] ?? null) ? $status['pid'] : null),
        'max_seconds' => $maxSeconds,
        'start_time' => microtime(true),
        'php_bin' => $phpBin,
        'stdout_path' => $stdoutPath !== false ? $stdoutPath : null,
        'stderr_path' => $stderrPath !== false ? $stderrPath : null,
        'timed_out' => false,
        'cancelled' => false,
        'uses_timeout' => $maxSeconds !== null,
        'timeout_signal' => $timeoutSignal,
        'timeout_signal_arg' => $timeoutSignalArg,
        'valgrind_log_path' => $valgrindLogPath,
        'rr_trace_dir' => $rrTraceDir,
        'rr_chaos_mode' => $rrBin !== null ? $rrChaosMode : null,
        'timeout_backtrace_path' => null,
        'timeout_backtrace_simple_path' => null,
        'command_string' => render_exec_command($execCommand, $rrTraceDir),
    ];
}

function finalize_command(array $job, array $status, ?int $timeoutSignal, bool $onlyCrashes): array
{
    $exitCode = proc_close($job['process']);
    $executionMs = elapsed_ms((float)($job['start_time'] ?? microtime(true)));
    $timedOut = (bool)($job['timed_out'] ?? false);

    $signal = null;
    if (($status['signaled'] ?? false) && isset($status['termsig'])) {
        $signal = (int)$status['termsig'];
    } elseif ($exitCode !== 0 && $exitCode > 128) {
        $signal = $exitCode - 128;
    }

    if ($timedOut) {
        $signal = null;
    }

    $observedPids = is_array($job['observed_pids'] ?? null) ? $job['observed_pids'] : [];
    $coreFiles = find_core_dumps_for_pids($job['php_bin'], $observedPids);
    if ($coreFiles === [] && $timedOut && !empty($job['uses_timeout'])) {
        $coreFiles = find_core_dumps($job['php_bin'], null, $job['start_time'] ?? null);
    }
    $isCrash = ($signal !== null && in_array($signal, CRASH_SIGNALS, true)) || $coreFiles !== [];
    $valgrindErrors = parse_valgrind_error_count($job['valgrind_log_path'] ?? null);
    if (is_int($valgrindErrors) && $valgrindErrors > 0) {
        $isCrash = true;
    }
    if (!$onlyCrashes) {
        $isCrash = ($job['timed_out'] || $timedOut) || $isCrash;
    }

    return [
        'exit_code' => $exitCode,
        'execution_ms' => $executionMs,
        'signal' => $signal,
        'pid' => $job['pid'],
        'timed_out' => $job['timed_out'] || $timedOut,
        'is_crash' => $isCrash,
        'core_files' => $coreFiles,
        'timeout_signal' => $timedOut ? ($job['timeout_signal_arg'] ?? null) : null,
        'stdout_path' => $job['stdout_path'],
        'stderr_path' => $job['stderr_path'],
        'valgrind_log_path' => $job['valgrind_log_path'] ?? null,
        'valgrind_errors' => $valgrindErrors,
        'rr_trace_dir' => $job['rr_trace_dir'] ?? null,
        'rr_chaos_mode' => $job['rr_chaos_mode'] ?? null,
        'timeout_backtrace_path' => $job['timeout_backtrace_path'] ?? null,
        'timeout_backtrace_simple_path' => $job['timeout_backtrace_simple_path'] ?? null,
    ];
}

function poll_command(array &$job, ?int $timeoutSignal, bool $onlyCrashes): ?array
{
    $status = proc_get_status($job['process']);
    if ($status['running']) {
        collect_process_tree_pids(
            is_int($job['pid'] ?? null) ? $job['pid'] : null,
            $job['observed_pids']
        );

        if (!empty($job['cancelled'])) {
            proc_terminate($job['process']);
            $cancelAt = $job['cancel_requested_at'] ?? $job['start_time'];
            if ((microtime(true) - $cancelAt) >= 1.0) {
                proc_terminate($job['process'], SIGKILL);
            }
            return null;
        }

        if (
            empty($job['timed_out'])
            && isset($job['max_seconds'])
            && is_int($job['max_seconds'])
            && (microtime(true) - ($job['start_time'] ?? 0.0)) >= $job['max_seconds']
        ) {
            $job['timed_out'] = true;
            [$job['timeout_backtrace_path'], $job['timeout_backtrace_simple_path']] = capture_timeout_backtraces(
                is_int($job['pid'] ?? null) ? $job['pid'] : null
            );
            proc_terminate($job['process'], $timeoutSignal ?? SIGTERM);
            $job['timeout_requested_at'] = microtime(true);
        } elseif (
            !empty($job['timed_out'])
            && isset($job['timeout_requested_at'])
            && (microtime(true) - (float)$job['timeout_requested_at']) >= 1.0
        ) {
            proc_terminate($job['process'], SIGKILL);
        }

        return null;
    }

    if ($status['running']) {
        for ($i = 0; $i < 10; $i++) {
            usleep(100000);
            $status = proc_get_status($job['process']);
            if (!$status['running']) {
                break;
            }
        }
    }

    return finalize_command($job, $status, $timeoutSignal, $onlyCrashes);
}

function cancel_command(array &$job): void
{
    if ($job['cancelled']) {
        return;
    }

    $job['cancelled'] = true;
    $job['cancel_requested_at'] = microtime(true);
    proc_terminate($job['process']);
}

function create_job(
    array $commandArgs,
    ?int $currentOps,
    string $phpBin,
    ?string $phpIni,
    array $phpArgs,
    int $jobId,
    ?int $maxSeconds,
    ?string $timeoutSignalArg,
    ?int $timeoutSignal,
    ?string $valgrindBin,
    ?string $rrBin,
    bool $rrChaosMode
): array {
    $dynamicArgs = array_map('replace_dynamic', $commandArgs);
    $dynamicPhpArgs = array_map('replace_dynamic', $phpArgs);
    $runArgs = array_map(static fn(string $arg): string => apply_ops($arg, $currentOps), $dynamicArgs);
    $fullCommand = build_php_command($phpBin, $phpIni, $dynamicPhpArgs, $runArgs);

    $job = start_command($fullCommand, $phpBin, $maxSeconds, $timeoutSignalArg, $timeoutSignal, $valgrindBin, $rrBin, $rrChaosMode);
    $job['id'] = $jobId;
    $job['dynamic_args'] = $dynamicArgs;
    $job['php_args'] = $dynamicPhpArgs;
    $job['full_command'] = $fullCommand;
    $job['command_string'] = $job['command_string'] ?? render_command(
        build_exec_command($fullCommand, $valgrindBin, $job['valgrind_log_path'] ?? null, $rrBin, $rrChaosMode)
    );
    $job['ops'] = $currentOps;

    return $job;
}

function normalize_fuzzer_mode(string $mode): string
{
    $mode = strtolower(trim($mode));
    if ($mode === '') {
        return 'random';
    }
    if (str_starts_with($mode, 'script')) {
        $parts = explode(':', $mode, 2);
        if (isset($parts[1]) && $parts[1] !== '') {
            return $parts[1];
        }
        return 'random';
    }
    return $mode;
}

function build_script_mode_args(array $runArgs): array
{
    $args = [];
    $mode = 'random';
    $sawMode = false;
    $count = count($runArgs);

    for ($i = 0; $i < $count; $i++) {
        $arg = $runArgs[$i];
        if ($arg === '--mode') {
            $sawMode = true;
            $mode = normalize_fuzzer_mode($runArgs[$i + 1] ?? '');
            $args[] = '--mode';
            $args[] = 'script:' . $mode;
            $i++;
            continue;
        }
        if (str_starts_with($arg, '--mode=')) {
            $sawMode = true;
            $value = substr($arg, strlen('--mode='));
            $mode = normalize_fuzzer_mode($value);
            $args[] = '--mode=script:' . $mode;
            continue;
        }
        $args[] = $arg;
    }

    if (!$sawMode) {
        $args[] = '--mode';
        $args[] = 'script:' . $mode;
    }

    return [$args, $mode];
}

function should_generate_script(array $runArgs): bool
{
    if ($runArgs === []) {
        return false;
    }
    $binary = basename($runArgs[0]);
    return $binary === 'fuzzer' || $binary === 'fuzzer.php';
}

function capture_script_artifacts(
    string $sourceDir,
    string $destinationDir,
    string $phpBin,
    ?string $phpIni,
    array $phpArgs,
    ?string $valgrindBin,
    ?string $rrBin,
    bool $rrChaosMode
): void
{
    $files = [
        'reproducer.php',
        'reproducer-generate.stderr',
    ];
    foreach ($files as $file) {
        $source = $sourceDir . '/' . $file;
        if (!is_file($source)) {
            continue;
        }
        $dest = $destinationDir . '/' . $file;
        if (file_exists($dest)) {
            @unlink($dest);
        }
        @copy($source, $dest);
    }

    write_run_reproducer($destinationDir, $phpBin, $phpIni, $phpArgs, $valgrindBin, $rrBin, $rrChaosMode);
}

function generate_reproducer_script(
    string $jobDir,
    string $phpBin,
    ?string $phpIni,
    array $phpArgs,
    array $runArgs,
    string $finalCommand,
    ?string $valgrindBin,
    ?string $rrBin,
    bool $rrChaosMode
): void {
    if (!should_generate_script($runArgs)) {
        return;
    }

    [$scriptArgs, $mode] = build_script_mode_args($runArgs);
    $fullCommand = build_php_command($phpBin, $phpIni, $phpArgs, $scriptArgs);
    $scriptPath = $jobDir . '/reproducer.php';
    $stderrPath = $jobDir . '/reproducer-generate.stderr';

    $contextLines = [
        'generated by relay-table-fuzzer harness',
        'captured: ' . date('c'),
        'fuzzer mode: ' . $mode,
        'fuzzer command: ' . $finalCommand,
        'script command: ' . render_command($fullCommand),
        'php bin: ' . $phpBin,
    ];
    if ($phpIni !== null && $phpIni !== '') {
        $contextLines[] = 'php ini: ' . $phpIni;
    }
    if ($phpArgs !== []) {
        $contextLines[] = 'php args: ' . render_command($phpArgs);
    }

    $env = getenv();
    if (!is_array($env)) {
        $env = [];
    }
    $env['RELAY_FUZZER_CONTEXT'] = implode("\n", $contextLines);

    $descriptorSpec = [
        0 => ['file', '/dev/null', 'r'],
        1 => ['file', $scriptPath, 'w'],
        2 => ['file', $stderrPath, 'w'],
    ];

    $process = proc_open($fullCommand, $descriptorSpec, $pipes, null, $env);
    if (!is_resource($process)) {
        file_put_contents($stderrPath, "failed to start script generator\n");
        return;
    }

    $status = proc_get_status($process);
    while ($status['running']) {
        usleep(10000);
        $status = proc_get_status($process);
    }

    $exitCode = proc_close($process);
    if ($exitCode !== 0) {
        file_put_contents($stderrPath, "script generator exit code: {$exitCode}\n", FILE_APPEND);
        return;
    }

    write_run_reproducer($jobDir, $phpBin, $phpIni, $phpArgs, $valgrindBin, $rrBin, $rrChaosMode);

    @chmod($scriptPath, 0755);
    if (is_file($stderrPath) && filesize($stderrPath) === 0) {
        @unlink($stderrPath);
    }
}

function create_script_job(
    array $commandArgs,
    ?int $currentOps,
    string $phpBin,
    ?string $phpIni,
    array $phpArgs,
    int $jobId,
    ?int $maxSeconds,
    ?string $timeoutSignalArg,
    ?int $timeoutSignal,
    ?string $valgrindBin,
    ?string $rrBin,
    bool $rrChaosMode
): array {
    $dynamicArgs = array_map('replace_dynamic', $commandArgs);
    $dynamicPhpArgs = array_map('replace_dynamic', $phpArgs);
    $runArgs = array_map(static fn(string $arg): string => apply_ops($arg, $currentOps), $dynamicArgs);

    $generatorCommand = build_php_command($phpBin, $phpIni, $dynamicPhpArgs, $runArgs);
    $generatorCommandString = render_command($generatorCommand);

    $scriptDir = create_temp_dir('relay-harness-script-');
    generate_reproducer_script(
        $scriptDir,
        $phpBin,
        $phpIni,
        $dynamicPhpArgs,
        $runArgs,
        $generatorCommandString,
        $valgrindBin,
        $rrBin,
        $rrChaosMode
    );

    $scriptPath = $scriptDir . '/reproducer.php';
    if (!is_file($scriptPath)) {
        $stderrPath = $scriptDir . '/reproducer-generate.stderr';
        $message = '';
        if (is_file($stderrPath)) {
            $message = trim((string)file_get_contents($stderrPath));
        }
        fwrite(STDERR, "Script generation failed. {$message}\n");
        exit(1);
    }

    $scriptCommand = build_php_command($phpBin, $phpIni, $dynamicPhpArgs, [$scriptPath]);
    $job = start_command($scriptCommand, $phpBin, $maxSeconds, $timeoutSignalArg, $timeoutSignal, $valgrindBin, $rrBin, $rrChaosMode);
    $job['id'] = $jobId;
    $job['dynamic_args'] = $dynamicArgs;
    $job['php_args'] = $dynamicPhpArgs;
    $job['full_command'] = $scriptCommand;
    $job['command_string'] = $job['command_string'] ?? render_command(
        build_exec_command($scriptCommand, $valgrindBin, $job['valgrind_log_path'] ?? null, $rrBin, $rrChaosMode)
    );
    $job['ops'] = $currentOps;
    $job['script_dir'] = $scriptDir;
    $job['script_path'] = $scriptPath;
    $job['generator_command'] = $generatorCommandString;

    return $job;
}

function reduce_ops(
    int $maxOps,
    array $dynamicArgs,
    string $phpBin,
    ?string $phpIni,
    array $phpArgs,
    array &$stats,
    string $jobDir,
    ?int $maxSeconds,
    ?string $timeoutSignalArg,
    ?int $timeoutSignal,
    ?string $valgrindBin,
    ?string $rrBin,
    bool $rrChaosMode,
    bool $onlyCrashes,
    float $renderInterval,
    float &$lastRenderTime
): int {
    $low = 1;
    $high = $maxOps;

    while ($low < $high) {
        $mid = intdiv($low + $high, 2);
        $runArgs = array_map(static fn(string $arg): string => apply_ops($arg, $mid), $dynamicArgs);
        $fullCommand = build_php_command($phpBin, $phpIni, $phpArgs, $runArgs);
        $result = run_command(
            $fullCommand,
            $phpBin,
            $maxSeconds,
            $timeoutSignalArg,
            $timeoutSignal,
            $onlyCrashes,
            $valgrindBin,
            $rrBin,
            $rrChaosMode
        );
        $commandString = render_command(build_exec_command(
            $fullCommand,
            $valgrindBin,
            $result['valgrind_log_path'] ?? null,
            $rrBin,
            $rrChaosMode
        ));
        $stats['runs']++;
        $stats['last_command'] = $commandString;
        $stats['last_event'] = "reducing ops: {$mid}";
        if ($result['is_crash']) {
            $stats['last_failure_time'] = microtime(true);
            $stats['last_failure_summary'] = build_failure_summary($result);
            $stats['last_event'] = "reducer crash at ops {$mid}";
            $movedCores = move_core_dumps($result['core_files'], $jobDir);
            generate_gdb_backtraces($movedCores, $jobDir, $phpBin);
        }
        cleanup_output_files($result);
        maybe_render_screen($stats, $mid, 'reducing', $renderInterval, $lastRenderTime, $result['is_crash']);
        if ($result['is_crash']) {
            $high = $mid;
            continue;
        }

        $low = $mid + 1;
    }

    return $low;
}

function reduce_ops_script(
    int $maxOps,
    array $dynamicArgs,
    string $phpBin,
    ?string $phpIni,
    array $phpArgs,
    array &$stats,
    string $jobDir,
    ?int $maxSeconds,
    ?string $timeoutSignalArg,
    ?int $timeoutSignal,
    ?string $valgrindBin,
    ?string $rrBin,
    bool $rrChaosMode,
    bool $onlyCrashes,
    float $renderInterval,
    float &$lastRenderTime
): int {
    $low = 1;
    $high = $maxOps;

    while ($low < $high) {
        $mid = intdiv($low + $high, 2);
        $runArgs = array_map(static fn(string $arg): string => apply_ops($arg, $mid), $dynamicArgs);
        $generatorCommand = build_php_command($phpBin, $phpIni, $phpArgs, $runArgs);
        $generatorCommandString = render_command($generatorCommand);

        $scriptDir = create_temp_dir('relay-harness-reduce-');
        generate_reproducer_script(
            $scriptDir,
            $phpBin,
            $phpIni,
            $phpArgs,
            $runArgs,
            $generatorCommandString,
            $valgrindBin,
            $rrBin,
            $rrChaosMode
        );
        $scriptPath = $scriptDir . '/reproducer.php';
        if (!is_file($scriptPath)) {
            remove_dir_recursive($scriptDir);
            fwrite(STDERR, "Script generation failed during reduction\n");
            exit(1);
        }

        $scriptCommand = build_php_command($phpBin, $phpIni, $phpArgs, [$scriptPath]);
        $result = run_command(
            $scriptCommand,
            $phpBin,
            $maxSeconds,
            $timeoutSignalArg,
            $timeoutSignal,
            $onlyCrashes,
            $valgrindBin,
            $rrBin,
            $rrChaosMode
        );
        $commandString = render_command(build_exec_command(
            $scriptCommand,
            $valgrindBin,
            $result['valgrind_log_path'] ?? null,
            $rrBin,
            $rrChaosMode
        ));
        $stats['runs']++;
        $stats['last_command'] = $commandString;
        $stats['last_event'] = "reducing ops: {$mid}";
        if ($result['is_crash']) {
            $stats['last_failure_time'] = microtime(true);
            $stats['last_failure_summary'] = build_failure_summary($result);
            $stats['last_event'] = "reducer crash at ops {$mid}";
            $movedCores = move_core_dumps($result['core_files'], $jobDir);
            generate_gdb_backtraces($movedCores, $jobDir, $phpBin);
        }
        cleanup_output_files($result);
        remove_dir_recursive($scriptDir);
        maybe_render_screen($stats, $mid, 'reducing', $renderInterval, $lastRenderTime, $result['is_crash']);
        if ($result['is_crash']) {
            $high = $mid;
            continue;
        }

        $low = $mid + 1;
    }

    return $low;
}

function resolve_php_binary_for_gdb(string $phpBin): ?string
{
    $resolved = resolve_executable_path($phpBin);
    if (is_link($resolved)) {
        $link = readlink($resolved);
        if ($link !== false) {
            if (substr($link, 0, 1) !== '/') {
                $link = dirname($resolved) . '/' . $link;
            }
            $resolved = $link;
        }
    }

    $real = realpath($resolved);
    if ($real !== false) {
        $resolved = $real;
    }

    return is_file($resolved) ? $resolved : null;
}

function write_gdb_shim(string $destinationDir, string $phpBin): void
{
    $entries = scandir($destinationDir);
    if ($entries === false) {
        return;
    }

    $coreFiles = [];
    foreach ($entries as $entry) {
        if (preg_match('/^core(?:\.|$)/', $entry) !== 1) {
            continue;
        }

        $path = realpath($destinationDir . '/' . $entry);
        if ($path !== false && is_file($path)) {
            $coreFiles[] = $path;
        }
    }

    sort($coreFiles);
    $coreFile = $coreFiles[0] ?? null;
    $phpPath = resolve_php_binary_for_gdb($phpBin);
    if ($coreFile === null || $phpPath === null) {
        return;
    }

    $shimPath = $destinationDir . '/gdb';
    $shimLines = [
        '#!/usr/bin/env bash',
        '',
        '# Auto-generated by relay-table-fuzzer harness.',
        'CORE_FILE=' . escapeshellarg($coreFile),
        'PHP_BIN=' . escapeshellarg($phpPath),
        'exec gdb -c "$CORE_FILE" "$PHP_BIN"',
    ];
    file_put_contents($shimPath, implode("\n", $shimLines) . "\n");
    @chmod($shimPath, 0755);
}

function find_gdb_binary(): ?string
{
    $output = [];
    $exitCode = 0;
    @exec('command -v gdb', $output, $exitCode);
    if ($exitCode !== 0 || $output === []) {
        return null;
    }

    $path = trim($output[0] ?? '');
    return $path !== '' ? $path : null;
}

function run_gdb_backtrace(string $gdb, string $phpPath, string $coreFile, string $tracePath, string $command): void
{
    $descriptorSpec = [
        0 => ['file', '/dev/null', 'r'],
        1 => ['file', $tracePath, 'w'],
        2 => ['file', $tracePath . '.err', 'w'],
    ];
    $gdbCommand = [
        $gdb,
        '-batch',
        '-ex',
        'set pagination off',
        '-ex',
        $command,
        $phpPath,
        $coreFile,
    ];
    $process = proc_open($gdbCommand, $descriptorSpec, $pipes);
    if (!is_resource($process)) {
        file_put_contents($tracePath, "failed to start gdb\n");
        return;
    }

    $status = proc_get_status($process);
    while (($status['running'] ?? false) === true) {
        usleep(10000);
        $status = proc_get_status($process);
    }

    proc_close($process);
}

function run_gdb_process_backtrace(string $gdb, int $pid, string $tracePath, string $command): void
{
    $descriptorSpec = [
        0 => ['file', '/dev/null', 'r'],
        1 => ['file', $tracePath, 'w'],
        2 => ['file', $tracePath . '.err', 'w'],
    ];
    $gdbCommand = [
        $gdb,
        '-batch',
        '-ex',
        'set pagination off',
        '-ex',
        'set confirm off',
        '-ex',
        $command,
        '-ex',
        'detach',
        '-p',
        (string)$pid,
    ];
    $process = proc_open($gdbCommand, $descriptorSpec, $pipes);
    if (!is_resource($process)) {
        file_put_contents($tracePath, "failed to start gdb\n");
        return;
    }

    $status = proc_get_status($process);
    while (($status['running'] ?? false) === true) {
        usleep(10000);
        $status = proc_get_status($process);
    }

    proc_close($process);
}

function capture_timeout_backtraces(?int $pid): array
{
    $fullTracePath = create_temp_log('relay-harness-timeout-bt-');
    $simpleTracePath = create_temp_log('relay-harness-timeout-bt-simple-');
    if ($fullTracePath === null || $simpleTracePath === null) {
        foreach ([$fullTracePath, $simpleTracePath] as $path) {
            if (is_string($path) && $path !== '' && file_exists($path)) {
                @unlink($path);
            }
        }
        return [null, null];
    }

    if ($pid === null) {
        file_put_contents($fullTracePath, "process pid unavailable for timeout backtrace\n");
        file_put_contents($simpleTracePath, "process pid unavailable for timeout backtrace\n");
        return [$fullTracePath, $simpleTracePath];
    }

    $gdb = find_gdb_binary();
    if ($gdb === null) {
        file_put_contents($fullTracePath, "gdb not found in PATH\n");
        file_put_contents($simpleTracePath, "gdb not found in PATH\n");
        return [$fullTracePath, $simpleTracePath];
    }

    run_gdb_process_backtrace($gdb, $pid, $fullTracePath, 'thread apply all bt full');
    run_gdb_process_backtrace($gdb, $pid, $simpleTracePath, 'thread apply all bt');

    return [$fullTracePath, $simpleTracePath];
}

function generate_gdb_backtraces(array $coreFiles, string $destinationDir, string $phpBin): void
{
    if ($coreFiles === []) {
        return;
    }

    $gdb = find_gdb_binary();
    $phpPath = resolve_php_binary_for_gdb($phpBin);

    $suffix = count($coreFiles) > 1;
    foreach ($coreFiles as $coreFile) {
        $base = basename($coreFile);
        $fullTracePath = $destinationDir . '/' . ($suffix ? "gdb-backtrace-{$base}.txt" : 'gdb-backtrace.txt');
        $simpleTracePath = $destinationDir . '/' . ($suffix ? "gdb-backtrace-simple-{$base}.txt" : 'gdb-backtrace-simple.txt');

        if ($gdb === null) {
            file_put_contents($fullTracePath, "gdb not found in PATH\n");
            file_put_contents($simpleTracePath, "gdb not found in PATH\n");
            continue;
        }

        if ($phpPath === null) {
            file_put_contents($fullTracePath, "php binary not found for gdb\n");
            file_put_contents($simpleTracePath, "php binary not found for gdb\n");
            continue;
        }

        run_gdb_backtrace($gdb, $phpPath, $coreFile, $fullTracePath, 'thread apply all bt full');
        run_gdb_backtrace($gdb, $phpPath, $coreFile, $simpleTracePath, 'thread apply all bt');
    }
}

function run_rr_gdb_backtrace(string $rrBin, string $rrTraceDir, string $tracePath): void
{
    $descriptorSpec = [
        0 => ['file', '/dev/null', 'r'],
        1 => ['file', $tracePath, 'w'],
        2 => ['file', $tracePath . '.err', 'w'],
    ];
    $rrCommand = [
        $rrBin,
        'replay',
        $rrTraceDir,
        '-M',
        '--',
        '-batch',
        '-ex',
        'set pagination off',
        '-ex',
        'set confirm off',
        '-ex',
        'continue',
        '-ex',
        'thread apply all bt full',
    ];
    file_put_contents($tracePath . '.command.txt', render_command($rrCommand) . "\n");

    $process = proc_open($rrCommand, $descriptorSpec, $pipes);
    if (!is_resource($process)) {
        file_put_contents($tracePath, "failed to start rr replay\n");
        return;
    }

    $status = proc_get_status($process);
    while (($status['running'] ?? false) === true) {
        usleep(10000);
        $status = proc_get_status($process);
    }

    $exitCode = proc_close($process);
    if ($exitCode !== 0) {
        file_put_contents($tracePath, "rr replay exit code: {$exitCode}\n", FILE_APPEND);
    }
}

function is_rr_recording_trace_dir(string $path): bool
{
    foreach (['version', 'data', 'tasks', 'events', 'mmaps'] as $traceFile) {
        if (!is_file($path . '/' . $traceFile)) {
            return false;
        }
    }

    return true;
}

function resolve_rr_replay_trace_dir(string $rrTraceDir): string
{
    if (is_rr_recording_trace_dir($rrTraceDir)) {
        return $rrTraceDir;
    }

    $latestTrace = $rrTraceDir . '/latest-trace';
    if (is_dir($latestTrace)) {
        $resolved = realpath($latestTrace);
        return is_string($resolved) ? $resolved : $latestTrace;
    }

    $entries = scandir($rrTraceDir);
    if ($entries === false) {
        return $rrTraceDir;
    }

    $traceDirs = [];
    foreach ($entries as $entry) {
        if ($entry === '.' || $entry === '..' || $entry === 'latest-trace') {
            continue;
        }

        $path = $rrTraceDir . '/' . $entry;
        if (is_dir($path) && is_rr_recording_trace_dir($path)) {
            $traceDirs[] = $path;
        }
    }

    if (count($traceDirs) !== 1) {
        return $rrTraceDir;
    }

    return $traceDirs[0];
}

function generate_rr_backtrace(string $rrBin, string $rrTraceDir, string $destinationDir): ?string
{
    if (!is_dir($rrTraceDir)) {
        return null;
    }

    $traceName = 'gdb-backtrace-rr.txt';
    $tracePath = $destinationDir . '/' . $traceName;
    run_rr_gdb_backtrace($rrBin, resolve_rr_replay_trace_dir($rrTraceDir), $tracePath);

    return $traceName;
}

function move_core_dumps(array $coreFiles, string $destinationDir): array
{
    $moved = [];
    foreach ($coreFiles as $coreFile) {
        $target = $destinationDir . '/' . basename($coreFile);
        if (@rename($coreFile, $target)) {
            $moved[] = $target;
            continue;
        }

        if (@copy($coreFile, $target)) {
            @unlink($coreFile);
            $moved[] = $target;
        }
    }

    return $moved;
}

function cleanup_output_files(array $result): void
{
    foreach (['stdout_path', 'stderr_path', 'valgrind_log_path', 'timeout_backtrace_path', 'timeout_backtrace_simple_path'] as $key) {
        $path = $result[$key] ?? null;
        if (is_string($path) && $path !== '' && file_exists($path)) {
            @unlink($path);
        }
    }

    $rrTraceDir = $result['rr_trace_dir'] ?? null;
    if (is_string($rrTraceDir) && $rrTraceDir !== '' && is_dir($rrTraceDir)) {
        remove_dir_recursive($rrTraceDir);
    }
}

function cleanup_discarded_job(array $result, array $job): void
{
    cleanup_output_files($result);

    $scriptDir = $job['script_dir'] ?? null;
    if (is_string($scriptDir) && $scriptDir !== '') {
        remove_dir_recursive($scriptDir);
    }
}

function move_output_files(array $result, string $destinationDir): array
{
    $moved = [];
    $mapping = [
        'stdout_path' => 'stdout.log',
        'stderr_path' => 'stderr.log',
        'valgrind_log_path' => 'valgrind.log',
        'timeout_backtrace_path' => 'gdb-timeout-backtrace.txt',
        'timeout_backtrace_simple_path' => 'gdb-timeout-backtrace-simple.txt',
    ];

    foreach ($mapping as $key => $targetName) {
        $path = $result[$key] ?? null;
        if (!is_string($path) || $path === '' || !file_exists($path)) {
            continue;
        }

        $target = $destinationDir . '/' . $targetName;
        if (file_exists($target)) {
            @unlink($target);
        }
        if (@rename($path, $target)) {
            $moved[] = $targetName;
            continue;
        }

        if (@copy($path, $target)) {
            @unlink($path);
            $moved[] = $targetName;
        }
    }

    return $moved;
}

function rename_output_file(string $destinationDir, string $sourceName, string $targetName): void
{
    if ($sourceName === $targetName) {
        return;
    }

    $sourcePath = $destinationDir . '/' . $sourceName;
    $targetPath = $destinationDir . '/' . $targetName;
    if (!is_file($sourcePath)) {
        return;
    }

    if (is_file($targetPath)) {
        @unlink($targetPath);
    }

    @rename($sourcePath, $targetPath);
}

function move_rr_trace_dir(?string $rrTraceDir, string $destinationDir, string $targetName = 'rr-trace'): ?string
{
    if (!is_string($rrTraceDir) || $rrTraceDir === '' || !is_dir($rrTraceDir)) {
        return null;
    }

    $target = $destinationDir . '/' . $targetName;
    if (file_exists($target)) {
        remove_dir_recursive($target);
    }

    if (@rename($rrTraceDir, $target)) {
        return $targetName;
    }

    if (copy_path_recursive($rrTraceDir, $target)) {
        remove_dir_recursive($rrTraceDir);
        return $targetName;
    }

    return null;
}

function move_reproducer_dir(string $jobDir, string $reproducersDir, bool $reproduced, ?string $bucket = null): string
{
    $bucket ??= $reproduced ? REPRODUCER_BUCKET_REPRODUCING : REPRODUCER_BUCKET_NON_REPRODUCING;
    $bucketDir = $reproducersDir . '/' . $bucket;
    if (!is_dir($bucketDir) && !mkdir($bucketDir, 0777, true) && !is_dir($bucketDir)) {
        return $jobDir;
    }

    for ($sequence = next_reproducer_sequence($reproducersDir); $sequence < PHP_INT_MAX; $sequence++) {
        $targetDir = $bucketDir . '/' . format_reproducer_sequence($sequence);
        if (!@mkdir($targetDir, 0777)) {
            continue;
        }

        if (move_dir_contents($jobDir, $targetDir)) {
            @rmdir($jobDir);
            return $targetDir;
        }

        remove_dir_recursive($targetDir);
        return $jobDir;
    }

    return $jobDir;
}

function next_reproducer_sequence(string $storageDir): int
{
    $max = 0;
    foreach (REPRODUCER_BUCKETS as $bucket) {
        $bucketDir = $storageDir . '/' . $bucket;
        if (!is_dir($bucketDir)) {
            continue;
        }

        $entries = scandir($bucketDir);
        if ($entries === false) {
            continue;
        }

        foreach ($entries as $entry) {
            if (preg_match('/^[0-9]+$/', $entry) !== 1) {
                continue;
            }
            $max = max($max, (int) $entry);
        }
    }

    return $max + 1;
}

function format_reproducer_sequence(int $sequence): string
{
    return str_pad((string) $sequence, 4, '0', STR_PAD_LEFT);
}

function move_dir_contents(string $sourceDir, string $targetDir): bool
{
    $entries = scandir($sourceDir);
    if ($entries === false) {
        return false;
    }

    $moved = [];
    foreach ($entries as $entry) {
        if ($entry === '.' || $entry === '..') {
            continue;
        }

        if (!@rename($sourceDir . '/' . $entry, $targetDir . '/' . $entry)) {
            foreach (array_reverse($moved) as $movedEntry) {
                @rename($targetDir . '/' . $movedEntry, $sourceDir . '/' . $movedEntry);
            }
            return false;
        }
        $moved[] = $entry;
    }

    return true;
}

function parse_relay_memory_from_output(?string $stdoutPath): ?array
{
    if (!is_string($stdoutPath) || $stdoutPath === '' || !is_file($stdoutPath)) {
        return null;
    }

    $lines = @file($stdoutPath, FILE_IGNORE_NEW_LINES);
    if ($lines === false) {
        return null;
    }

    $prefix = 'RELAY_MEMORY_JSON:';
    for ($i = count($lines) - 1; $i >= 0; $i--) {
        $line = trim($lines[$i]);
        if ($line === '') {
            continue;
        }
        if (strpos($line, $prefix) === 0) {
            $line = trim(substr($line, strlen($prefix)));
        }
        if ($line === '') {
            continue;
        }
        $data = json_decode($line, true);
        if (!is_array($data)) {
            continue;
        }
        if (!isset($data['total'], $data['limit'], $data['active'], $data['used'])) {
            continue;
        }
        return $data;
    }

    return null;
}

function parse_php_leak_count_from_file(?string $path): ?int
{
    if (!is_string($path) || $path === '' || !is_file($path)) {
        return null;
    }

    $lines = @file($path, FILE_IGNORE_NEW_LINES);
    if ($lines === false) {
        return null;
    }

    for ($i = count($lines) - 1; $i >= 0; $i--) {
        $line = trim($lines[$i]);
        if ($line === '') {
            continue;
        }
        if (preg_match('/^===\s*Total\s+(\d+)\s+memory\s+leaks\s+detected\s+===/i', $line, $matches)) {
            return (int)$matches[1];
        }
    }

    return null;
}

function parse_php_leak_count(?string $stdoutPath, ?string $stderrPath): ?int
{
    $count = parse_php_leak_count_from_file($stderrPath);
    if ($count !== null) {
        return $count;
    }

    return parse_php_leak_count_from_file($stdoutPath);
}

function parse_valgrind_error_count(?string $path): ?int
{
    if (!is_string($path) || $path === '' || !is_file($path)) {
        return null;
    }

    $lines = @file($path, FILE_IGNORE_NEW_LINES);
    if ($lines === false) {
        return null;
    }

    for ($i = count($lines) - 1; $i >= 0; $i--) {
        $line = trim($lines[$i]);
        if ($line === '') {
            continue;
        }
        if (preg_match('/ERROR\s+SUMMARY:\s*(\d+)\s+errors/i', $line, $matches)) {
            return (int)$matches[1];
        }
    }

    return null;
}

function build_failure_summary(array $result): string
{
    if (!empty($result['timed_out'])) {
        return 'TIMEOUT';
    }

    if (!empty($result['core_files'])) {
        return 'core';
    }

    if ($result['signal'] !== null) {
        return signal_label($result['signal']);
    }

    $valgrindErrors = $result['valgrind_errors'] ?? null;
    if (is_int($valgrindErrors) && $valgrindErrors > 0) {
        return "VALGRIND_{$valgrindErrors}";
    }

    return 'EXIT_' . $result['exit_code'];
}

function ensure_core_ulimit_unlimited(): void
{
    $output = [];
    $exitCode = 0;
    exec('sh -c "ulimit -c"', $output, $exitCode);
    $value = $output !== [] ? trim($output[0]) : '';

    if ($exitCode !== 0 || $value !== 'unlimited') {
        fwrite(STDERR, "Core dump ulimit is not unlimited (ulimit -c returned \"{$value}\").\n");
        fwrite(STDERR, "Set it with: ulimit -c unlimited\n");
        exit(1);
    }
}

$argv = $_SERVER['argv'];
$argc = $_SERVER['argc'];

$phpBin = null;
$phpIni = null;
$phpArgs = [];
$ops = null;
$reduce = false;
$harnessMode = 'fuzz';
$onlyCrashes = false;
$capturePhpLeaks = false;
$maxSeconds = null;
$timeoutSignalArg = null;
$timeoutSignal = null;
$jobs = 1;
$renderInterval = 1.0;
$reproTries = 1;
$valgrindBin = null;
$rrBin = null;
$rrChaosMode = false;
$commandArgs = [];

for ($i = 1; $i < $argc; $i++) {
    $arg = $argv[$i];
    if ($arg === '--') {
        $commandArgs = array_slice($argv, $i + 1);
        break;
    }

    if ($arg === '--help' || $arg === '-h') {
        fwrite(STDOUT, usage($argv[0]) . "\n");
        exit(0);
    }

    if ($arg === '--php-bin') {
        $phpBin = $argv[++$i] ?? null;
        continue;
    }

    if ($arg === '--php-ini') {
        $phpIni = $argv[++$i] ?? null;
        continue;
    }

    if ($arg === '-d') {
        $value = $argv[++$i] ?? null;
        if ($value === null || $value === '') {
            fwrite(STDERR, "-d requires a non-empty ini=value\n");
            fwrite(STDERR, usage($argv[0]) . "\n");
            exit(1);
        }
        $phpArgs[] = '-d';
        $phpArgs[] = $value;
        continue;
    }

    if (str_starts_with($arg, '-d')) {
        $value = substr($arg, 2);
        if ($value === '') {
            fwrite(STDERR, "-d requires a non-empty ini=value\n");
            fwrite(STDERR, usage($argv[0]) . "\n");
            exit(1);
        }
        $phpArgs[] = '-d';
        $phpArgs[] = $value;
        continue;
    }

    if ($arg === '--ops') {
        $ops = $argv[++$i] ?? null;
        $ops = is_numeric($ops) ? (int)$ops : null;
        continue;
    }

    if ($arg === '--reduce') {
        $reduce = true;
        continue;
    }

    if ($arg === '--mode') {
        $harnessMode = strtolower((string) ($argv[++$i] ?? ''));
        continue;
    }

    if (str_starts_with($arg, '--mode=')) {
        $harnessMode = strtolower(substr($arg, strlen('--mode=')));
        continue;
    }

    if ($arg === '--valgrind') {
        $valgrindBin = 'valgrind';
        continue;
    }

    if (str_starts_with($arg, '--valgrind=')) {
        $value = substr($arg, strlen('--valgrind='));
        if ($value === '') {
            fwrite(STDERR, "--valgrind requires a binary path or name\n");
            fwrite(STDERR, usage($argv[0]) . "\n");
            exit(1);
        }
        $valgrindBin = $value;
        continue;
    }

    if ($arg === '--rr') {
        $rrBin = 'rr';
        continue;
    }

    if ($arg === '--rr-chaos-mode') {
        $rrBin = 'rr';
        $rrChaosMode = true;
        continue;
    }

    if ($arg === '--only-crashes') {
        $onlyCrashes = true;
        continue;
    }

    if ($arg === '--capture-php-leaks') {
        $capturePhpLeaks = true;
        continue;
    }

    if ($arg === '--timeout') {
        $maxSeconds = $argv[++$i] ?? null;
        $maxSeconds = is_numeric($maxSeconds) ? (int)$maxSeconds : null;
        continue;
    }

    if ($arg === '--timeout-signal') {
        $signalValue = $argv[++$i] ?? null;
        $parsed = parse_timeout_signal($signalValue);
        if ($parsed === null) {
            fwrite(STDERR, "--timeout-signal requires a valid signal name or number\n");
            fwrite(STDERR, usage($argv[0]) . "\n");
            exit(1);
        }
        $timeoutSignalArg = $parsed['arg'];
        $timeoutSignal = $parsed['num'];
        continue;
    }

    if ($arg === '--jobs') {
        $jobs = $argv[++$i] ?? null;
        $jobs = is_numeric($jobs) ? (int)$jobs : null;
        continue;
    }

    if ($arg === '--interval') {
        $renderInterval = $argv[++$i] ?? null;
        $renderInterval = is_numeric($renderInterval) ? (float)$renderInterval : null;
        continue;
    }

    if ($arg === '--repro-tries') {
        $reproTries = $argv[++$i] ?? null;
        $reproTries = is_numeric($reproTries) ? (int)$reproTries : null;
        continue;
    }

    fwrite(STDERR, "Unknown option: {$arg}\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($phpBin === null || $phpBin === '') {
    fwrite(STDERR, "Missing required --php-bin\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($commandArgs === []) {
    fwrite(STDERR, "Missing command after --\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

$usesOps = false;
foreach ($commandArgs as $arg) {
    if (strpos($arg, '{ops}') !== false) {
        $usesOps = true;
        break;
    }
}

if ($usesOps && $ops === null) {
    fwrite(STDERR, "Missing required --ops for {ops} replacement\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($reduce && !$usesOps) {
    fwrite(STDERR, "--reduce requires {ops} in the command arguments\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($reduce && ($ops === null || $ops <= 0)) {
    fwrite(STDERR, "--reduce requires a positive --ops value\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($maxSeconds !== null && $maxSeconds <= 0) {
    fwrite(STDERR, "--timeout requires a positive integer\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($timeoutSignalArg !== null && $maxSeconds === null) {
    fwrite(STDERR, "--timeout-signal requires --timeout\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($onlyCrashes && $timeoutSignal !== null && in_array($timeoutSignal, CRASH_SIGNALS, true)) {
    fwrite(STDERR, "you can't set the timeout signal to a crash signal and then ask for only crashes\n");
    exit(1);
}

if ($jobs === null || $jobs <= 0) {
    fwrite(STDERR, "--jobs requires a positive integer\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($renderInterval === null || $renderInterval <= 0) {
    fwrite(STDERR, "--interval requires a positive number\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($reproTries === null || $reproTries <= 0) {
    fwrite(STDERR, "--repro-tries requires a positive integer\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

$harnessMode = strtolower(trim($harnessMode));
if ($harnessMode === '') {
    $harnessMode = 'fuzz';
}
if (!in_array($harnessMode, ['fuzz', 'script'], true)) {
    fwrite(STDERR, "Invalid --mode: {$harnessMode} (use fuzz or script)\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($harnessMode === 'script' && !should_generate_script($commandArgs)) {
    fwrite(STDERR, "--mode=script requires the command after -- to be bin/fuzzer\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($valgrindBin !== null && $harnessMode !== 'script') {
    fwrite(STDERR, "--valgrind is only supported with --mode=script\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($valgrindBin !== null && $rrBin !== null) {
    fwrite(STDERR, "--rr and --valgrind cannot be combined\n");
    fwrite(STDERR, usage($argv[0]) . "\n");
    exit(1);
}

if ($valgrindBin !== null) {
    $resolvedValgrind = resolve_executable_path($valgrindBin);
    if ($resolvedValgrind === '' || !is_file($resolvedValgrind) || !is_executable($resolvedValgrind)) {
        fwrite(STDERR, "valgrind binary not found or not executable: {$valgrindBin}\n");
        exit(1);
    }
    $valgrindBin = $resolvedValgrind;
}

if ($rrBin !== null) {
    $resolvedRr = resolve_executable_path($rrBin);
    if ($resolvedRr === '' || !is_file($resolvedRr) || !is_executable($resolvedRr)) {
        fwrite(STDERR, "rr binary not found or not executable: {$rrBin}\n");
        exit(1);
    }
    $rrBin = $resolvedRr;
}

ensure_core_ulimit_unlimited();

$reproducersDir = __DIR__ . '/../reproducers';
if (!is_dir($reproducersDir)) {
    mkdir($reproducersDir, 0777, true);
}
$reproducerCounts = count_reproducer_dirs($reproducersDir);
$leaksDir = __DIR__ . '/../leaks';
if (!is_dir($leaksDir)) {
    mkdir($leaksDir, 0777, true);
}

$currentOps = $ops;
$stats = [
    'start_time' => microtime(true),
    'runs' => 0,
    'reproducers' => $reproducerCounts['total'],
    'reproducers_reproducing' => $reproducerCounts['reproducing'],
    'last_failure_time' => null,
    'last_failure_summary' => '',
    'reductions' => 0,
    'last_command' => '',
    'last_event' => '',
    'last_reproducer' => '',
    'active_jobs' => 0,
    'relay_memory' => null,
    'recent_reproducer_roots' => [$reproducersDir, $leaksDir],
];

$jobCounter = 0;
$runningJobs = [];
$crashResult = null;
$crashJob = null;
$stopAfterCrash = false;
$leakResult = null;
$leakJob = null;
$stopAfterLeak = false;
$lastRenderTime = 0.0;

while (true) {
    $progress = false;

    while (!$stopAfterCrash && !$stopAfterLeak && count($runningJobs) < $jobs) {
        $jobCounter++;
        if ($harnessMode === 'script') {
            $job = create_script_job(
                $commandArgs,
                $currentOps,
                $phpBin,
                $phpIni,
                $phpArgs,
                $jobCounter,
                $maxSeconds,
                $timeoutSignalArg,
                $timeoutSignal,
                $valgrindBin,
                $rrBin,
                $rrChaosMode
            );
        } else {
            $job = create_job(
                $commandArgs,
                $currentOps,
                $phpBin,
                $phpIni,
                $phpArgs,
                $jobCounter,
                $maxSeconds,
                $timeoutSignalArg,
                $timeoutSignal,
                $valgrindBin,
                $rrBin,
                $rrChaosMode
            );
        }
        $runningJobs[$job['id']] = $job;
        $stats['last_command'] = $job['command_string'];
        $stats['last_event'] = "spawned job {$job['id']}";
        $progress = true;
    }

    $stats['active_jobs'] = count($runningJobs);

    foreach ($runningJobs as $jobId => &$job) {
        $result = poll_command($job, $timeoutSignal, $onlyCrashes);
        if ($result === null) {
            continue;
        }

        $progress = true;
        unset($runningJobs[$jobId]);
        $stats['runs']++;
        $stats['last_command'] = $job['command_string'];
        $stats['last_event'] = "job {$jobId} finished";

        if ($job['cancelled']) {
            cleanup_discarded_job($result, $job);
            continue;
        }

        $leakCount = null;
        if ($capturePhpLeaks) {
            $leakCount = parse_php_leak_count($result['stdout_path'], $result['stderr_path']);
        }

        if (
            $result['exit_code'] === 0
            && $result['signal'] === null
            && !$result['timed_out']
            && !$result['is_crash']
        ) {
            $memory = parse_relay_memory_from_output($result['stdout_path']);
            if ($memory !== null) {
                $stats['relay_memory'] = $memory;
            }
        }

        if ($result['is_crash'] && $crashResult === null) {
            $crashResult = $result;
            $crashJob = $job;
            $stats['last_failure_time'] = microtime(true);
            $stats['last_failure_summary'] = build_failure_summary($result);
            $stats['last_event'] = 'crash detected';
            $stopAfterCrash = true;

            foreach ($runningJobs as &$pendingJob) {
                cancel_command($pendingJob);
            }
        } elseif ($leakCount !== null && $leakResult === null && !$result['is_crash']) {
            $result['leak_count'] = $leakCount;
            $leakResult = $result;
            $leakJob = $job;
            $stats['last_failure_time'] = microtime(true);
            $stats['last_failure_summary'] = "LEAKS: {$leakCount}";
            $stats['last_event'] = 'leak detected';
            $stopAfterLeak = true;

            foreach ($runningJobs as &$pendingJob) {
                cancel_command($pendingJob);
            }
        } else {
            cleanup_discarded_job($result, $job);
        }

        $stats['active_jobs'] = count($runningJobs);
        maybe_render_screen(
            $stats,
            $currentOps,
            $stopAfterCrash ? 'reducing' : ($harnessMode === 'script' ? 'script' : 'fuzzing'),
            $renderInterval,
            $lastRenderTime,
            $result['is_crash'] || $leakCount !== null
        );
    }
    unset($job);

    maybe_render_screen(
        $stats,
        $currentOps,
        $stopAfterCrash ? 'reducing' : ($harnessMode === 'script' ? 'script' : 'fuzzing'),
        $renderInterval,
        $lastRenderTime
    );

    if ($crashResult !== null && $runningJobs === []) {
        $jobDir = create_reproducer_work_dir($reproducersDir);

        $finalCommand = $crashJob['command_string'];
        $finalOps = $currentOps;
        $originalOps = $currentOps;
        $dynamicArgs = $crashJob['dynamic_args'];
        $finalPhpArgs = $crashJob['php_args'] ?? [];
        $finalGeneratorCommand = $crashJob['generator_command'] ?? null;

        if ($reduce && $currentOps !== null) {
            $stats['reductions']++;
            $stats['active_jobs'] = 1;
            if ($harnessMode === 'script') {
                $finalOps = reduce_ops_script(
                    $currentOps,
                    $dynamicArgs,
                    $phpBin,
                    $phpIni,
                    $finalPhpArgs,
                    $stats,
                    $jobDir,
                    $maxSeconds,
                    $timeoutSignalArg,
                    $timeoutSignal,
                    $valgrindBin,
                    $rrBin,
                    $rrChaosMode,
                    $onlyCrashes,
                    $renderInterval,
                    $lastRenderTime
                );
            } else {
                $finalOps = reduce_ops(
                    $currentOps,
                    $dynamicArgs,
                    $phpBin,
                    $phpIni,
                    $finalPhpArgs,
                    $stats,
                    $jobDir,
                    $maxSeconds,
                    $timeoutSignalArg,
                    $timeoutSignal,
                    $valgrindBin,
                    $rrBin,
                    $rrChaosMode,
                    $onlyCrashes,
                    $renderInterval,
                    $lastRenderTime
                );
                $reducedArgs = array_map(static fn(string $arg): string => apply_ops($arg, $finalOps), $dynamicArgs);
                $finalCommand = render_command(build_exec_command(
                    build_php_command($phpBin, $phpIni, $finalPhpArgs, $reducedArgs),
                    $valgrindBin,
                    $valgrindBin !== null ? $jobDir . '/valgrind.log' : null,
                    $rrBin,
                    $rrChaosMode
                ));

                if ($finalCommand !== $crashJob['command_string']) {
                    file_put_contents($jobDir . '/command-original.txt', $crashJob['command_string'] . "\n");
                }
            }
        }

        $finalRunArgs = array_map(static fn(string $arg): string => apply_ops($arg, $finalOps), $dynamicArgs);
        if ($harnessMode === 'script') {
            $finalGeneratorCommand = render_command(build_php_command($phpBin, $phpIni, $finalPhpArgs, $finalRunArgs));
        } elseif ($rrBin !== null) {
            $finalExecCommand = build_exec_command(
                build_php_command($phpBin, $phpIni, $finalPhpArgs, $finalRunArgs),
                $valgrindBin,
                null,
                $rrBin,
                $rrChaosMode
            );
            $finalCommand = render_exec_command($finalExecCommand, $jobDir . '/rr-reproducer-trace');
        }

        $outputFiles = move_output_files($crashResult, $jobDir);
        $rrTraceDir = move_rr_trace_dir($crashResult['rr_trace_dir'] ?? null, $jobDir);
        cleanup_output_files($crashResult);

        if ($harnessMode === 'script') {
            $shouldRegenerate = $reduce && $finalOps !== null && $finalOps !== $originalOps;
            if (!$shouldRegenerate && isset($crashJob['script_dir'])) {
                capture_script_artifacts(
                    (string) $crashJob['script_dir'],
                    $jobDir,
                    $phpBin,
                    $phpIni,
                    $finalPhpArgs,
                    $valgrindBin,
                    $rrBin,
                    $rrChaosMode
                );
            } else {
                generate_reproducer_script(
                    $jobDir,
                    $phpBin,
                    $phpIni,
                    $finalPhpArgs,
                    $finalRunArgs,
                    $finalGeneratorCommand ?? $finalCommand,
                    $valgrindBin,
                    $rrBin,
                    $rrChaosMode
                );
            }
            $finalExecCommand = build_exec_command(
                build_php_command($phpBin, $phpIni, $finalPhpArgs, [$jobDir . '/reproducer.php']),
                $valgrindBin,
                $valgrindBin !== null ? $jobDir . '/valgrind.log' : null,
                $rrBin,
                $rrChaosMode
            );
            $finalCommand = render_exec_command($finalExecCommand, $rrBin !== null ? $jobDir . '/rr-reproducer-trace' : null);
            file_put_contents($jobDir . '/command.txt', $finalCommand . "\n");
            if ($finalGeneratorCommand !== null) {
                file_put_contents($jobDir . '/generator-command.txt', $finalGeneratorCommand . "\n");
                if ($reduce && $finalOps !== null && $finalOps !== $originalOps && isset($crashJob['generator_command'])) {
                    file_put_contents($jobDir . '/generator-command-original.txt', $crashJob['generator_command'] . "\n");
                }
            }
        } else {
            file_put_contents($jobDir . '/command.txt', $finalCommand . "\n");
            generate_reproducer_script(
                $jobDir,
                $phpBin,
                $phpIni,
                $finalPhpArgs,
                $finalRunArgs,
                $finalCommand,
                $valgrindBin,
                $rrBin,
                $rrChaosMode
            );
        }

        $movedCores = move_core_dumps($crashResult['core_files'], $jobDir);
        generate_gdb_backtraces($movedCores, $jobDir, $phpBin);

        $signal = $crashResult['signal'];
        $exitCode = $crashResult['exit_code'];
        $pid = $crashResult['pid'];
        $rrBacktracePath = null;
        if (
            $rrBin !== null
            && $rrTraceDir !== null
            && $signal !== null
            && in_array($signal, CRASH_SIGNALS, true)
        ) {
            $stats['last_event'] = 'capturing rr backtrace';
            maybe_render_screen($stats, $currentOps, 'capturing', $renderInterval, $lastRenderTime, true);
            $rrBacktracePath = generate_rr_backtrace($rrBin, $jobDir . '/' . $rrTraceDir, $jobDir);
        }

        $signalLabel = $signal !== null ? signal_label($signal) : 'none';
        $signalDesc = $signal !== null ? signal_description($signal) : '';
        $exitName = build_failure_summary($crashResult);
        $exitType = extract_gdb_error_type($jobDir) ?? normalize_failure_label($exitName);
        $reportOps = $finalOps ?? extract_ops_from_args($finalRunArgs);

        $reportData = [
            'command' => $finalCommand,
            'exit_code' => $exitCode,
            'exit_name' => $exitName,
            'exit_type' => $exitType,
            'signal' => $signalLabel,
        ];
        $reportData = with_report_ops($reportData, $reportOps);
        if ($signalDesc !== '') {
            $reportData['signal_desc'] = $signalDesc;
        }
        if (!empty($crashResult['timed_out'])) {
            $reportData['timed_out'] = true;
            if ($maxSeconds !== null) {
                $reportData['max_seconds'] = $maxSeconds;
            }
            if (!empty($crashResult['timeout_signal'])) {
                $reportData['timeout_signal'] = $crashResult['timeout_signal'];
            }
        }
        $reportData['pid'] = $pid ?? 'unknown';
        if (!empty($crashResult['core_files'])) {
            $reportData['core_files'] = array_map('basename', $crashResult['core_files']);
        }
        if (is_int($crashResult['valgrind_errors'] ?? null)) {
            $reportData['valgrind_errors'] = $crashResult['valgrind_errors'];
        }
        if ($outputFiles !== []) {
            $reportData['output_files'] = $outputFiles;
        }
        if ($rrTraceDir !== null) {
            $reportData['rr_trace_dir'] = $rrTraceDir;
            $reportData['rr_chaos_mode'] = $rrChaosMode;
        }
        if ($rrBacktracePath !== null) {
            $reportData['rr_backtrace'] = $rrBacktracePath;
        }
        if ($harnessMode === 'script' && $finalGeneratorCommand !== null) {
            $reportData['generator_command'] = $finalGeneratorCommand;
        }

        write_report_files($jobDir, $reportData);
        $reproducerScript = $jobDir . '/reproducer.php';
        $reproducerCrash = $rrBin !== null && $rrTraceDir !== null;
        $reproducerExecutionMs = null;
        if ($reproducerCrash) {
            $reportData['reproducer_status'] = 'recorded-by-rr';
            write_report_files($jobDir, $reportData);
        } elseif (is_file($reproducerScript)) {
            $reproducerCommand = build_php_command($phpBin, $phpIni, $finalPhpArgs, [$reproducerScript]);
            for ($attempt = 1; $attempt <= $reproTries; $attempt++) {
                $stats['last_event'] = $reproTries > 1
                    ? "running reproducer ({$attempt}/{$reproTries})"
                    : 'running reproducer';
                $reproducerResult = run_command(
                    $reproducerCommand,
                    $phpBin,
                    $maxSeconds,
                    $timeoutSignalArg,
                    $timeoutSignal,
                    $onlyCrashes,
                    $valgrindBin,
                    $rrBin,
                    $rrChaosMode
                );
                $reproducerExecutionMs = ($reproducerExecutionMs ?? 0) + (int)($reproducerResult['execution_ms'] ?? 0);
                if ($valgrindBin !== null) {
                    $reproducerCrash = (int)($reproducerResult['valgrind_errors'] ?? 0) > 0;
                } else {
                    $reproducerCrash = $reproducerResult['is_crash'];
                }
                if (!empty($reproducerResult['valgrind_errors'])) {
                    $targetName = $reproTries > 1
                        ? "valgrind-reproducer-attempt-{$attempt}.log"
                        : 'valgrind-reproducer.log';
                    $movedValgrind = move_output_files(
                        [
                            'valgrind_log_path' => $reproducerResult['valgrind_log_path'] ?? null,
                        ],
                        $jobDir
                    );
                    if ($movedValgrind !== [] && $targetName !== 'valgrind.log') {
                        rename_output_file($jobDir, 'valgrind.log', $targetName);
                    }
                }
                if (!empty($reproducerResult['timeout_backtrace_path']) || !empty($reproducerResult['timeout_backtrace_simple_path'])) {
                    move_output_files(
                        [
                            'timeout_backtrace_path' => $reproducerResult['timeout_backtrace_path'] ?? null,
                            'timeout_backtrace_simple_path' => $reproducerResult['timeout_backtrace_simple_path'] ?? null,
                        ],
                        $jobDir
                    );
                    if ($reproTries > 1) {
                        rename_output_file($jobDir, 'gdb-timeout-backtrace.txt', "gdb-timeout-backtrace-attempt-{$attempt}.txt");
                        rename_output_file(
                            $jobDir,
                            'gdb-timeout-backtrace-simple.txt',
                            "gdb-timeout-backtrace-simple-attempt-{$attempt}.txt"
                        );
                    }
                }
                if (!empty($reproducerResult['core_files'])) {
                    $reproducerCores = move_core_dumps($reproducerResult['core_files'], $jobDir);
                    generate_gdb_backtraces($reproducerCores, $jobDir, $phpBin);
                }
                cleanup_output_files($reproducerResult);
                if ($reproducerCrash) {
                    break;
                }
            }
        }
        if ($reproducerExecutionMs !== null) {
            $reportData['reproducer_execution_ms'] = $reproducerExecutionMs;
            write_report_files($jobDir, $reportData);
        }

        $finalJobDir = move_reproducer_dir(
            $jobDir,
            $reproducersDir,
            $reproducerCrash,
            $reproducerCrash && $rrBin !== null ? REPRODUCER_BUCKET_REPRODUCABLE : null
        );
        rewrite_saved_reproducer_command(
            $finalJobDir,
            $reportData,
            $phpBin,
            $phpIni,
            $finalPhpArgs,
            $valgrindBin,
            $rrBin,
            $rrChaosMode
        );
        write_gdb_shim($finalJobDir, $phpBin);
        if ($harnessMode === 'script' && isset($crashJob['script_dir'])) {
            remove_dir_recursive((string) $crashJob['script_dir']);
        }

        $stats['reproducers']++;
        if ($reproducerCrash) {
            $stats['reproducers_reproducing']++;
        }
        $stats['last_event'] = 'reproducer saved: ' . display_path($finalJobDir);
        $stats['last_reproducer'] = $finalJobDir;
        $stats['active_jobs'] = 0;
        maybe_render_screen(
            $stats,
            $currentOps,
            $reduce ? 'reducing' : ($harnessMode === 'script' ? 'script' : 'fuzzing'),
            $renderInterval,
            $lastRenderTime,
            true
        );

        if ($reduce && $finalOps !== null && $reproducerCrash) {
            $currentOps = $finalOps;
        }

        $crashResult = null;
        $crashJob = null;
        $stopAfterCrash = false;
        continue;
    }

    if ($leakResult !== null && $runningJobs === []) {
        $jobDir = create_reproducer_work_dir($leaksDir);

        $finalCommand = $leakJob['command_string'];
        $finalOps = $currentOps;
        $dynamicArgs = $leakJob['dynamic_args'];
        $finalPhpArgs = $leakJob['php_args'] ?? [];
        $finalGeneratorCommand = $leakJob['generator_command'] ?? null;

        $finalRunArgs = array_map(static fn(string $arg): string => apply_ops($arg, $finalOps), $dynamicArgs);
        if ($harnessMode === 'script') {
            $finalGeneratorCommand = render_command(build_php_command($phpBin, $phpIni, $finalPhpArgs, $finalRunArgs));
        } elseif ($rrBin !== null) {
            $finalExecCommand = build_exec_command(
                build_php_command($phpBin, $phpIni, $finalPhpArgs, $finalRunArgs),
                $valgrindBin,
                null,
                $rrBin,
                $rrChaosMode
            );
            $finalCommand = render_exec_command($finalExecCommand, $jobDir . '/rr-reproducer-trace');
        } else {
            file_put_contents($jobDir . '/command.txt', $finalCommand . "\n");
        }

        $outputFiles = move_output_files($leakResult, $jobDir);
        $rrTraceDir = move_rr_trace_dir($leakResult['rr_trace_dir'] ?? null, $jobDir);
        cleanup_output_files($leakResult);

        if ($harnessMode === 'script') {
            if (isset($leakJob['script_dir'])) {
                capture_script_artifacts(
                    (string) $leakJob['script_dir'],
                    $jobDir,
                    $phpBin,
                    $phpIni,
                    $finalPhpArgs,
                    $valgrindBin,
                    $rrBin,
                    $rrChaosMode
                );
            } else {
                generate_reproducer_script(
                    $jobDir,
                    $phpBin,
                    $phpIni,
                    $finalPhpArgs,
                    $finalRunArgs,
                    $finalGeneratorCommand ?? $finalCommand,
                    $valgrindBin,
                    $rrBin,
                    $rrChaosMode
                );
            }
            $finalExecCommand = build_exec_command(
                build_php_command($phpBin, $phpIni, $finalPhpArgs, [$jobDir . '/reproducer.php']),
                $valgrindBin,
                $valgrindBin !== null ? $jobDir . '/valgrind.log' : null,
                $rrBin,
                $rrChaosMode
            );
            $finalCommand = render_exec_command($finalExecCommand, $rrBin !== null ? $jobDir . '/rr-reproducer-trace' : null);
            file_put_contents($jobDir . '/command.txt', $finalCommand . "\n");
            if ($finalGeneratorCommand !== null) {
                file_put_contents($jobDir . '/generator-command.txt', $finalGeneratorCommand . "\n");
            }
        } else {
            file_put_contents($jobDir . '/command.txt', $finalCommand . "\n");
            generate_reproducer_script(
                $jobDir,
                $phpBin,
                $phpIni,
                $finalPhpArgs,
                $finalRunArgs,
                $finalCommand,
                $valgrindBin,
                $rrBin,
                $rrChaosMode
            );
        }

        $movedCores = move_core_dumps($leakResult['core_files'], $jobDir);
        generate_gdb_backtraces($movedCores, $jobDir, $phpBin);

        $signal = $leakResult['signal'];
        $exitCode = $leakResult['exit_code'];
        $pid = $leakResult['pid'];
        $leakCount = $leakResult['leak_count'] ?? null;

        $signalLabel = $signal !== null ? signal_label($signal) : 'none';
        $signalDesc = $signal !== null ? signal_description($signal) : '';
        $exitName = build_failure_summary($leakResult);
        $exitType = extract_gdb_error_type($jobDir) ?? normalize_failure_label($exitName);
        $reportOps = $finalOps ?? extract_ops_from_args($finalRunArgs);

        $reportData = [
            'command' => $finalCommand,
            'exit_code' => $exitCode,
            'exit_name' => $exitName,
            'exit_type' => $exitType,
            'signal' => $signalLabel,
        ];
        $reportData = with_report_ops($reportData, $reportOps);
        if ($signalDesc !== '') {
            $reportData['signal_desc'] = $signalDesc;
        }
        if (!empty($leakResult['timed_out'])) {
            $reportData['timed_out'] = true;
            if ($maxSeconds !== null) {
                $reportData['max_seconds'] = $maxSeconds;
            }
            if (!empty($leakResult['timeout_signal'])) {
                $reportData['timeout_signal'] = $leakResult['timeout_signal'];
            }
        }
        $reportData['pid'] = $pid ?? 'unknown';
        if ($leakCount !== null) {
            $reportData['leak_count'] = $leakCount;
        }
        if (!empty($leakResult['core_files'])) {
            $reportData['core_files'] = array_map('basename', $leakResult['core_files']);
        }
        if (is_int($leakResult['valgrind_errors'] ?? null)) {
            $reportData['valgrind_errors'] = $leakResult['valgrind_errors'];
        }
        if ($outputFiles !== []) {
            $reportData['output_files'] = $outputFiles;
        }
        if ($rrTraceDir !== null) {
            $reportData['rr_trace_dir'] = $rrTraceDir;
            $reportData['rr_chaos_mode'] = $rrChaosMode;
        }
        if ($harnessMode === 'script' && $finalGeneratorCommand !== null) {
            $reportData['generator_command'] = $finalGeneratorCommand;
        }

        write_report_files($jobDir, $reportData);
        $reproducerScript = $jobDir . '/reproducer.php';
        $reproducerLeak = false;
        $reproducerExecutionMs = null;
        if (is_file($reproducerScript)) {
            $reproducerCommand = build_php_command($phpBin, $phpIni, $finalPhpArgs, [$reproducerScript]);
            for ($attempt = 1; $attempt <= $reproTries; $attempt++) {
                $stats['last_event'] = $reproTries > 1
                    ? "running leak reproducer ({$attempt}/{$reproTries})"
                    : 'running leak reproducer';
                $reproducerResult = run_command(
                    $reproducerCommand,
                    $phpBin,
                    $maxSeconds,
                    $timeoutSignalArg,
                    $timeoutSignal,
                    $onlyCrashes,
                    $valgrindBin,
                    $rrBin,
                    $rrChaosMode
                );
                $reproducerExecutionMs = ($reproducerExecutionMs ?? 0) + (int)($reproducerResult['execution_ms'] ?? 0);
                $reproducerLeak = parse_php_leak_count(
                    $reproducerResult['stdout_path'],
                    $reproducerResult['stderr_path']
                ) !== null;
                if (!empty($reproducerResult['valgrind_errors'])) {
                    $targetName = $reproTries > 1
                        ? "valgrind-leak-reproducer-attempt-{$attempt}.log"
                        : 'valgrind-leak-reproducer.log';
                    $movedValgrind = move_output_files(
                        [
                            'valgrind_log_path' => $reproducerResult['valgrind_log_path'] ?? null,
                        ],
                        $jobDir
                    );
                    if ($movedValgrind !== [] && $targetName !== 'valgrind.log') {
                        rename_output_file($jobDir, 'valgrind.log', $targetName);
                    }
                }
                if (!empty($reproducerResult['timeout_backtrace_path']) || !empty($reproducerResult['timeout_backtrace_simple_path'])) {
                    move_output_files(
                        [
                            'timeout_backtrace_path' => $reproducerResult['timeout_backtrace_path'] ?? null,
                            'timeout_backtrace_simple_path' => $reproducerResult['timeout_backtrace_simple_path'] ?? null,
                        ],
                        $jobDir
                    );
                    if ($reproTries > 1) {
                        rename_output_file($jobDir, 'gdb-timeout-backtrace.txt', "gdb-timeout-backtrace-attempt-{$attempt}.txt");
                        rename_output_file(
                            $jobDir,
                            'gdb-timeout-backtrace-simple.txt',
                            "gdb-timeout-backtrace-simple-attempt-{$attempt}.txt"
                        );
                    }
                }
                if (!empty($reproducerResult['core_files'])) {
                    $reproducerCores = move_core_dumps($reproducerResult['core_files'], $jobDir);
                    generate_gdb_backtraces($reproducerCores, $jobDir, $phpBin);
                }
                cleanup_output_files($reproducerResult);
                if ($reproducerLeak) {
                    break;
                }
            }
        }
        if ($reproducerExecutionMs !== null) {
            $reportData['reproducer_execution_ms'] = $reproducerExecutionMs;
            write_report_files($jobDir, $reportData);
        }

        $finalJobDir = move_reproducer_dir($jobDir, $leaksDir, $reproducerLeak);
        rewrite_saved_reproducer_command(
            $finalJobDir,
            $reportData,
            $phpBin,
            $phpIni,
            $finalPhpArgs,
            $valgrindBin,
            $rrBin,
            $rrChaosMode
        );
        write_gdb_shim($finalJobDir, $phpBin);
        if ($harnessMode === 'script' && isset($leakJob['script_dir'])) {
            remove_dir_recursive((string) $leakJob['script_dir']);
        }

        $stats['last_event'] = 'leak saved: ' . display_path($finalJobDir);
        $stats['last_reproducer'] = $finalJobDir;
        $stats['active_jobs'] = 0;
        maybe_render_screen(
            $stats,
            $currentOps,
            $reduce ? 'reducing' : ($harnessMode === 'script' ? 'script' : 'fuzzing'),
            $renderInterval,
            $lastRenderTime,
            true
        );

        $leakResult = null;
        $leakJob = null;
        $stopAfterLeak = false;
        continue;
    }

    if (!$progress) {
        usleep(10000);
    }
}
